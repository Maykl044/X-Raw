<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Светлая палитра -->
  <Color x:Key="X.Color.Canvas">#FFF6F7FB</Color>
  <Color x:Key="X.Color.CanvasMid">#FFFFFFFF</Color>
  <Color x:Key="X.Color.Surface">#FFFFFFFF</Color>
  <Color x:Key="X.Color.SurfaceHi">#FFF0F2F7</Color>
  <Color x:Key="X.Color.Outline">#55000000</Color>
  <Color x:Key="X.Color.OutlineSoft">#33000000</Color>

  <Color x:Key="X.Color.Accent">#FF6747FF</Color>
  <Color x:Key="X.Color.Accent2">#FF008CD9</Color>
  <Color x:Key="X.Color.Success">#FF00A878</Color>
  <Color x:Key="X.Color.Warn">#FFE89B22</Color>
  <Color x:Key="X.Color.Danger">#FFE63956</Color>

  <Color x:Key="X.Color.Text">#FF1A1B26</Color>
  <Color x:Key="X.Color.TextSoft">#CC4A4F62</Color>
  <Color x:Key="X.Color.TextMuted">#884A4F62</Color>

  <Color x:Key="X.Color.BgGlow1">#FF6747FF</Color>
  <Color x:Key="X.Color.BgGlow2">#FF008CD9</Color>
  <!-- Светлый фон: лёгкая подкраска голубым/лавандой, чтобы стекло читалось -->
  <Color x:Key="X.Color.BgGrad1">#FFE8ECF8</Color>
  <Color x:Key="X.Color.BgGrad2">#FFE2EAF6</Color>
  <Color x:Key="X.Color.BgGrad3">#FFEEEAF6</Color>

  <Color x:Key="X.Color.DangerTint">#22E63956</Color>
  <Color x:Key="X.Color.WarnTint">#22E89B22</Color>
  <Color x:Key="X.Color.AccentTint">#226747FF</Color>

  <!-- Liquid Glass (iOS 26 / Vision Pro): полупрозрачные слои -->
  <!-- Светлая тема: чуть плотнее заливка + заметнее бордер для читаемости -->
  <Color x:Key="X.Color.GlassFill">#B3FFFFFF</Color>
  <Color x:Key="X.Color.GlassFillStrong">#D9FFFFFF</Color>
  <Color x:Key="X.Color.GlassBorder">#66000000</Color>
  <Color x:Key="X.Color.GlassHighlight">#A6FFFFFF</Color>
  <Color x:Key="X.Color.GlassShadow">#33000000</Color>

  <Color x:Key="X.Color.PowerOff1">#22D8DCEA</Color>
  <Color x:Key="X.Color.PowerOff2">#0EE2E5EE</Color>
  <Color x:Key="X.Color.PowerOff3">#00F6F7FB</Color>
  <Color x:Key="X.Color.PowerOn1">#556747FF</Color>
  <Color x:Key="X.Color.PowerOn2">#33008CD9</Color>
  <Color x:Key="X.Color.PowerOn3">#00F6F7FB</Color>
</ResourceDictionary>
