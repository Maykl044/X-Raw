<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- =========================================================
       X-Rav · современная тёмная тема (purple-cyan accent)
       ========================================================= -->

  <!-- Палитра загружается из Theme/Colors.Dark.xaml или Colors.Light.xaml в ThemeService -->

  <SolidColorBrush x:Key="X.Brush.Canvas"      Color="{StaticResource X.Color.Canvas}" />
  <SolidColorBrush x:Key="X.Brush.CanvasMid"   Color="{StaticResource X.Color.CanvasMid}" />
  <SolidColorBrush x:Key="X.Brush.Surface"     Color="{StaticResource X.Color.Surface}" />
  <SolidColorBrush x:Key="X.Brush.SurfaceHi"   Color="{StaticResource X.Color.SurfaceHi}" />
  <SolidColorBrush x:Key="X.Brush.Outline"     Color="{StaticResource X.Color.Outline}" />
  <SolidColorBrush x:Key="X.Brush.OutlineSoft" Color="{StaticResource X.Color.OutlineSoft}" />
  <SolidColorBrush x:Key="X.Brush.Accent"      Color="{StaticResource X.Color.Accent}" />
  <SolidColorBrush x:Key="X.Brush.Accent2"     Color="{StaticResource X.Color.Accent2}" />
  <SolidColorBrush x:Key="X.Brush.Success"     Color="{StaticResource X.Color.Success}" />
  <SolidColorBrush x:Key="X.Brush.Warn"        Color="{StaticResource X.Color.Warn}" />
  <SolidColorBrush x:Key="X.Brush.Danger"      Color="{StaticResource X.Color.Danger}" />
  <SolidColorBrush x:Key="X.Brush.Text"        Color="{StaticResource X.Color.Text}" />
  <SolidColorBrush x:Key="X.Brush.TextSoft"    Color="{StaticResource X.Color.TextSoft}" />
  <SolidColorBrush x:Key="X.Brush.TextMuted"   Color="{StaticResource X.Color.TextMuted}" />
  <SolidColorBrush x:Key="X.Brush.DangerTint"  Color="{StaticResource X.Color.DangerTint}" />
  <SolidColorBrush x:Key="X.Brush.WarnTint"    Color="{StaticResource X.Color.WarnTint}" />
  <SolidColorBrush x:Key="X.Brush.AccentTint"  Color="{StaticResource X.Color.AccentTint}" />

  <LinearGradientBrush x:Key="X.Brush.Bg" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{StaticResource X.Color.BgGrad1}" Offset="0" />
    <GradientStop Color="{StaticResource X.Color.BgGrad2}" Offset="0.45" />
    <GradientStop Color="{StaticResource X.Color.BgGrad3}" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="X.Brush.AccentGrad" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{StaticResource X.Color.Accent}" Offset="0" />
    <GradientStop Color="{StaticResource X.Color.Accent2}" Offset="1" />
  </LinearGradientBrush>

  <RadialGradientBrush x:Key="X.Brush.PowerOff" GradientOrigin="0.4,0.35">
    <GradientStop Color="{StaticResource X.Color.PowerOff1}" Offset="0" />
    <GradientStop Color="{StaticResource X.Color.PowerOff2}" Offset="0.7" />
    <GradientStop Color="{StaticResource X.Color.PowerOff3}" Offset="1" />
  </RadialGradientBrush>

  <RadialGradientBrush x:Key="X.Brush.PowerOn" GradientOrigin="0.4,0.35">
    <GradientStop Color="{StaticResource X.Color.PowerOn1}" Offset="0" />
    <GradientStop Color="{StaticResource X.Color.PowerOn2}" Offset="0.5" />
    <GradientStop Color="{StaticResource X.Color.PowerOn3}" Offset="1" />
  </RadialGradientBrush>

  <!-- Типографика -->
  <Style x:Key="X.Text.H1" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource X.Brush.Text}" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>
  <Style x:Key="X.Text.H2" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource X.Brush.Text}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style x:Key="X.Text.Body" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource X.Brush.TextSoft}" />
    <Setter Property="FontSize" Value="13" />
  </Style>
  <Style x:Key="X.Text.Caption" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource X.Brush.TextMuted}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <!-- Backwards-compat aliases (старые имена в существующих view) -->
  <SolidColorBrush x:Key="Xrav.Brush.Canvas"        Color="{StaticResource X.Color.Canvas}" />
  <SolidColorBrush x:Key="Xrav.Brush.Surface"       Color="{StaticResource X.Color.Surface}" />
  <SolidColorBrush x:Key="Xrav.Brush.GlassTint"     Color="{StaticResource X.Color.Surface}" />
  <SolidColorBrush x:Key="Xrav.Brush.GlassStroke"   Color="{StaticResource X.Color.Outline}" />
  <SolidColorBrush x:Key="Xrav.Brush.Accent"        Color="{StaticResource X.Color.Accent}" />
  <SolidColorBrush x:Key="Xrav.Brush.TextPrimary"   Color="{StaticResource X.Color.Text}" />
  <SolidColorBrush x:Key="Xrav.Brush.TextSecondary" Color="{StaticResource X.Color.TextSoft}" />
  <SolidColorBrush x:Key="Xrav.Brush.TextMuted"     Color="{StaticResource X.Color.TextMuted}" />
  <SolidColorBrush x:Key="Xrav.Brush.Outline"       Color="{StaticResource X.Color.Outline}" />
  <Style x:Key="Xrav.Text.Title"   TargetType="TextBlock" BasedOn="{StaticResource X.Text.H2}" />
  <Style x:Key="Xrav.Text.Body"    TargetType="TextBlock" BasedOn="{StaticResource X.Text.Body}" />
  <Style x:Key="Xrav.Text.Caption" TargetType="TextBlock" BasedOn="{StaticResource X.Text.Caption}" />

  <!-- Кнопка primary (акцентная) -->
  <Style x:Key="X.Btn.Primary" TargetType="Button">
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="{StaticResource X.Brush.AccentGrad}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Opacity" Value="0.9" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Opacity" Value="0.75" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bd" Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Кнопка ghost (контурная, тёмный фон) -->
  <Style x:Key="X.Btn.Ghost" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource X.Brush.Text}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="12,7" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource X.Brush.Outline}" />
    <Setter Property="Background" Value="{StaticResource X.Brush.SurfaceHi}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource X.Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Opacity" Value="0.75" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bd" Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Кнопка danger -->
  <Style x:Key="X.Btn.Danger" TargetType="Button" BasedOn="{StaticResource X.Btn.Ghost}">
    <Setter Property="Foreground" Value="{StaticResource X.Brush.Danger}" />
  </Style>

  <!-- Кнопка-ссылка (для About) -->
  <Style x:Key="X.Btn.Link" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource X.Brush.Accent}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="Transparent">
            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                       FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}"
                       TextDecorations="Underline" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Foreground" Value="{StaticResource X.Brush.Accent2}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- Глобальный BooleanToVisibilityConverter -->
  <BooleanToVisibilityConverter x:Key="BoolToVisHelper" />

  <!-- TextBox -->
  <Style x:Key="X.TextBox" TargetType="TextBox">
    <Setter Property="Foreground" Value="{StaticResource X.Brush.Text}" />
    <Setter Property="CaretBrush" Value="{StaticResource X.Brush.Accent}" />
    <Setter Property="SelectionBrush" Value="{StaticResource X.Brush.Accent}" />
    <Setter Property="Background" Value="{StaticResource X.Brush.CanvasMid}" />
    <Setter Property="BorderBrush" Value="{StaticResource X.Brush.Outline}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" Focusable="False" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource X.Brush.Accent}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ListBoxItem с состоянием выбора -->
  <Style x:Key="X.ListBoxItem" TargetType="ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,0,0,6" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border x:Name="bd" Background="{StaticResource X.Brush.Surface}" CornerRadius="12"
                  BorderBrush="{StaticResource X.Brush.OutlineSoft}" BorderThickness="1" Padding="12,10">
            <ContentPresenter />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource X.Brush.Outline}" />
              <Setter TargetName="bd" Property="Background" Value="{StaticResource X.Brush.SurfaceHi}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource X.Brush.Accent}" />
              <Setter TargetName="bd" Property="Background" Value="{StaticResource X.Brush.SurfaceHi}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ListBox без рамки и с прозрачным фоном -->
  <Style x:Key="X.ListBox" TargetType="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    <Setter Property="ItemContainerStyle" Value="{StaticResource X.ListBoxItem}" />
  </Style>
</ResourceDictionary>
