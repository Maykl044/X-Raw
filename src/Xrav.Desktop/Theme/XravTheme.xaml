<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Токены: тёмная схема (Android XravDarkColors) -->
  <Color x:Key="XravColor.Canvas">#FF0B0D1A</Color>
  <Color x:Key="XravColor.Surface">#FF161A2B</Color>
  <Color x:Key="XravColor.SurfaceMuted">#FF1E2335</Color>
  <Color x:Key="XravColor.GlassTint">#B31B2136</Color>
  <Color x:Key="XravColor.GlassStroke">#33FFFFFF</Color>
  <Color x:Key="XravColor.Accent">#FF4AA3FF</Color>
  <Color x:Key="XravColor.TextPrimary">#FFEDF0F7</Color>
  <Color x:Key="XravColor.TextSecondary">#CCBFC5D4</Color>
  <Color x:Key="XravColor.TextMuted">#99BFC5D4</Color>
  <Color x:Key="XravColor.Outline">#33FFFFFF</Color>
  <Color x:Key="XravColor.Danger">#FFFF453A</Color>
  <Color x:Key="XravColor.Success">#FF30D158</Color>

  <SolidColorBrush x:Key="Xrav.Brush.Canvas" Color="{StaticResource XravColor.Canvas}" />
  <SolidColorBrush x:Key="Xrav.Brush.Surface" Color="{StaticResource XravColor.Surface}" />
  <SolidColorBrush x:Key="Xrav.Brush.GlassTint" Color="{StaticResource XravColor.GlassTint}" />
  <SolidColorBrush x:Key="Xrav.Brush.GlassStroke" Color="{StaticResource XravColor.GlassStroke}" />
  <SolidColorBrush x:Key="Xrav.Brush.Accent" Color="{StaticResource XravColor.Accent}" />
  <SolidColorBrush x:Key="Xrav.Brush.TextPrimary" Color="{StaticResource XravColor.TextPrimary}" />
  <SolidColorBrush x:Key="Xrav.Brush.TextSecondary" Color="{StaticResource XravColor.TextSecondary}" />
  <SolidColorBrush x:Key="Xrav.Brush.TextMuted" Color="{StaticResource XravColor.TextMuted}" />
  <SolidColorBrush x:Key="Xrav.Brush.Outline" Color="{StaticResource XravColor.Outline}" />

  <Style x:Key="Xrav.Text.Title" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource Xrav.Brush.TextPrimary}" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style x:Key="Xrav.Text.Body" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource Xrav.Brush.TextSecondary}" />
    <Setter Property="FontSize" Value="14" />
  </Style>
  <Style x:Key="Xrav.Text.Caption" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource Xrav.Brush.TextMuted}" />
    <Setter Property="FontSize" Value="12" />
  </Style>
</ResourceDictionary>
