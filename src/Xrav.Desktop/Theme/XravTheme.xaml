<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:ui="clr-namespace:Xrav.Desktop.Ui">

  <!-- X-Rav · единая дизайн-система (Liquid-Glass).
       Палитра грузится из Theme/Colors.{Dark|Light}.xaml в ThemeService. -->

  <SolidColorBrush x:Key="X.Brush.Canvas"      Color="{DynamicResource X.Color.Canvas}" />
  <SolidColorBrush x:Key="X.Brush.CanvasMid"   Color="{DynamicResource X.Color.CanvasMid}" />
  <SolidColorBrush x:Key="X.Brush.Surface"     Color="{DynamicResource X.Color.Surface}" />
  <SolidColorBrush x:Key="X.Brush.SurfaceHi"   Color="{DynamicResource X.Color.SurfaceHi}" />
  <SolidColorBrush x:Key="X.Brush.Outline"     Color="{DynamicResource X.Color.Outline}" />
  <SolidColorBrush x:Key="X.Brush.OutlineSoft" Color="{DynamicResource X.Color.OutlineSoft}" />
  <SolidColorBrush x:Key="X.Brush.Accent"      Color="{DynamicResource X.Color.Accent}" />
  <SolidColorBrush x:Key="X.Brush.Accent2"     Color="{DynamicResource X.Color.Accent2}" />
  <SolidColorBrush x:Key="X.Brush.Success"     Color="{DynamicResource X.Color.Success}" />
  <SolidColorBrush x:Key="X.Brush.Warn"        Color="{DynamicResource X.Color.Warn}" />
  <SolidColorBrush x:Key="X.Brush.Danger"      Color="{DynamicResource X.Color.Danger}" />
  <SolidColorBrush x:Key="X.Brush.Text"        Color="{DynamicResource X.Color.Text}" />
  <SolidColorBrush x:Key="X.Brush.TextSoft"    Color="{DynamicResource X.Color.TextSoft}" />
  <SolidColorBrush x:Key="X.Brush.TextMuted"   Color="{DynamicResource X.Color.TextMuted}" />
  <SolidColorBrush x:Key="X.Brush.DangerTint"  Color="{DynamicResource X.Color.DangerTint}" />
  <SolidColorBrush x:Key="X.Brush.WarnTint"    Color="{DynamicResource X.Color.WarnTint}" />
  <SolidColorBrush x:Key="X.Brush.AccentTint"  Color="{DynamicResource X.Color.AccentTint}" />

  <!-- Liquid Glass: полупрозрачные кисти -->
  <SolidColorBrush x:Key="X.Brush.GlassFill"        Color="{DynamicResource X.Color.GlassFill}" />
  <SolidColorBrush x:Key="X.Brush.GlassFillStrong"  Color="{DynamicResource X.Color.GlassFillStrong}" />
  <SolidColorBrush x:Key="X.Brush.GlassBorder"      Color="{DynamicResource X.Color.GlassBorder}" />
  <SolidColorBrush x:Key="X.Brush.GlassHighlight"   Color="{DynamicResource X.Color.GlassHighlight}" />
  <SolidColorBrush x:Key="X.Brush.GlassShadow"      Color="{DynamicResource X.Color.GlassShadow}" />

  <LinearGradientBrush x:Key="X.Brush.GlassSheen" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="{DynamicResource X.Color.GlassHighlight}" Offset="0" />
    <GradientStop Color="#00000000" Offset="0.45" />
    <GradientStop Color="#00000000" Offset="1" />
  </LinearGradientBrush>

  <!-- Карточка: полупрозрачное стекло + 1px обводка + мягкая тень. -->
  <Style x:Key="X.Card" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource X.Brush.GlassFill}" />
    <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.GlassBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="14" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect Color="{DynamicResource X.Color.GlassShadow}" BlurRadius="22" ShadowDepth="0" Opacity="0.35" />
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="X.Card.Strong" TargetType="Border" BasedOn="{StaticResource X.Card}">
    <Setter Property="Background" Value="{DynamicResource X.Brush.GlassFillStrong}" />
  </Style>
  <!-- Совместимость со старыми именами в XAML -->
  <Style x:Key="X.Card.Glass"        TargetType="Border" BasedOn="{StaticResource X.Card}" />
  <Style x:Key="X.Card.Glass.Strong" TargetType="Border" BasedOn="{StaticResource X.Card.Strong}" />

  <LinearGradientBrush x:Key="X.Brush.Bg" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{DynamicResource X.Color.BgGrad1}" Offset="0" />
    <GradientStop Color="{DynamicResource X.Color.BgGrad2}" Offset="0.45" />
    <GradientStop Color="{DynamicResource X.Color.BgGrad3}" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="X.Brush.AccentGrad" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{DynamicResource X.Color.Accent}" Offset="0" />
    <GradientStop Color="{DynamicResource X.Color.Accent2}" Offset="1" />
  </LinearGradientBrush>

  <!-- Цветные градиентные бейджи для иконок секций настроек.
       Используются как Background у X.Settings.IconBadge. -->
  <LinearGradientBrush x:Key="X.Brush.GreenGrad" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FF22C55E" Offset="0" />
    <GradientStop Color="#FF16A34A" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="X.Brush.AmberGrad" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FFF59E0B" Offset="0" />
    <GradientStop Color="#FFD97706" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="X.Brush.PurpleGrad" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FF8B5CF6" Offset="0" />
    <GradientStop Color="#FF6D28D9" Offset="1" />
  </LinearGradientBrush>

  <RadialGradientBrush x:Key="X.Brush.PowerOff" GradientOrigin="0.4,0.35">
    <GradientStop Color="{DynamicResource X.Color.PowerOff1}" Offset="0" />
    <GradientStop Color="{DynamicResource X.Color.PowerOff2}" Offset="0.7" />
    <GradientStop Color="{DynamicResource X.Color.PowerOff3}" Offset="1" />
  </RadialGradientBrush>

  <RadialGradientBrush x:Key="X.Brush.PowerOn" GradientOrigin="0.4,0.35">
    <GradientStop Color="{DynamicResource X.Color.PowerOn1}" Offset="0" />
    <GradientStop Color="{DynamicResource X.Color.PowerOn2}" Offset="0.5" />
    <GradientStop Color="{DynamicResource X.Color.PowerOn3}" Offset="1" />
  </RadialGradientBrush>

  <!-- Типографика -->
  <!-- Глобальный default TextBlock: Segoe UI с фолбэком на Segoe UI Emoji
       (для рендера флагов 🇷🇺 🇹🇷 🇺🇸 и любых эмодзи) и Segoe UI Symbol. -->
  <FontFamily x:Key="X.Font.Ui">Segoe UI, Segoe UI Emoji, Segoe UI Symbol</FontFamily>
  <Style TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource X.Font.Ui}" />
  </Style>
  <Style TargetType="ContentControl">
    <Setter Property="FontFamily" Value="{StaticResource X.Font.Ui}" />
  </Style>

  <Style x:Key="X.Text.H1" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource X.Font.Ui}" />
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>
  <Style x:Key="X.Text.H2" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource X.Font.Ui}" />
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style x:Key="X.Text.Body" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource X.Font.Ui}" />
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.TextSoft}" />
    <Setter Property="FontSize" Value="13" />
  </Style>
  <Style x:Key="X.Text.Caption" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource X.Font.Ui}" />
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.TextSoft}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- Backwards-compat aliases (старые имена в существующих view) -->
  <SolidColorBrush x:Key="Xrav.Brush.Canvas"        Color="{DynamicResource X.Color.Canvas}" />
  <SolidColorBrush x:Key="Xrav.Brush.Surface"       Color="{DynamicResource X.Color.Surface}" />
  <SolidColorBrush x:Key="Xrav.Brush.GlassTint"     Color="{DynamicResource X.Color.Surface}" />
  <SolidColorBrush x:Key="Xrav.Brush.GlassStroke"   Color="{DynamicResource X.Color.Outline}" />
  <SolidColorBrush x:Key="Xrav.Brush.Accent"        Color="{DynamicResource X.Color.Accent}" />
  <SolidColorBrush x:Key="Xrav.Brush.TextPrimary"   Color="{DynamicResource X.Color.Text}" />
  <SolidColorBrush x:Key="Xrav.Brush.TextSecondary" Color="{DynamicResource X.Color.TextSoft}" />
  <SolidColorBrush x:Key="Xrav.Brush.TextMuted"     Color="{DynamicResource X.Color.TextMuted}" />
  <SolidColorBrush x:Key="Xrav.Brush.Outline"       Color="{DynamicResource X.Color.Outline}" />
  <Style x:Key="Xrav.Text.Title"   TargetType="TextBlock" BasedOn="{StaticResource X.Text.H2}" />
  <Style x:Key="Xrav.Text.Body"    TargetType="TextBlock" BasedOn="{StaticResource X.Text.Body}" />
  <Style x:Key="Xrav.Text.Caption" TargetType="TextBlock" BasedOn="{StaticResource X.Text.Caption}" />

  <!-- Кнопка primary: акцент-градиент + dynamic cursor lighting + плавный hover scale. -->
  <Style x:Key="X.Btn.Primary" TargetType="Button">
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="14,7" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="{DynamicResource X.Brush.AccentGrad}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="ui:CursorLight.Enabled" Value="True" />
    <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="12"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Opacity" Value="0.94" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="bd"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     To="1.04" Duration="0:0:0.18">
                      <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="bd"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     To="1.04" Duration="0:0:0.18">
                      <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="bd"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     To="1" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetName="bd"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     To="1" Duration="0:0:0.18" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Opacity" Value="0.78" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bd" Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Кнопка ghost: стеклянная, контурная + dynamic cursor lighting + плавный hover scale. -->
  <Style x:Key="X.Btn.Ghost" TargetType="Button">
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.GlassBorder}" />
    <Setter Property="Background" Value="{DynamicResource X.Brush.GlassFill}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="ui:CursorLight.Enabled" Value="True" />
    <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="12"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource X.Brush.GlassFillStrong}" />
              <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="bd"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     To="1.04" Duration="0:0:0.18">
                      <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="bd"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     To="1.04" Duration="0:0:0.18">
                      <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="bd"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     To="1" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetName="bd"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     To="1" Duration="0:0:0.18" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Opacity" Value="0.78" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bd" Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Кнопка danger: ghost + красный текст/обводка. -->
  <Style x:Key="X.Btn.Danger" TargetType="Button" BasedOn="{StaticResource X.Btn.Ghost}">
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Danger}" />
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.Danger}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- Дефолт для всех Button без явного стиля → ghost. -->
  <Style TargetType="Button" BasedOn="{StaticResource X.Btn.Ghost}" />

  <!-- Кнопка-ссылка (для About) -->
  <Style x:Key="X.Btn.Link" TargetType="Button">
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Accent}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="Transparent">
            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                       FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}"
                       TextDecorations="Underline" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Foreground" Value="{DynamicResource X.Brush.Accent2}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- Глобальный BooleanToVisibilityConverter -->
  <BooleanToVisibilityConverter x:Key="BoolToVisHelper" />
  <ui:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
  <ui:NullToVisibilityCollapsedConverter x:Key="NullToVisCollapsed" />
  <ui:StringToVisibilityCollapsedConverter x:Key="StringToVisCollapsed" />

  <!-- Pill-бейдж (флаги/протоколы/латентность). -->
  <Style x:Key="X.Badge.Pill" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource X.Brush.GlassFill}" />
    <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.GlassBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <!-- CheckBox -->
  <Style x:Key="X.CheckBox" TargetType="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
    <Setter Property="FontFamily" Value="{StaticResource X.Font.Ui}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <StackPanel Orientation="Horizontal">
            <Border x:Name="box" Width="18" Height="18" CornerRadius="5"
                    Background="{DynamicResource X.Brush.GlassFill}"
                    BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1"
                    VerticalAlignment="Center">
              <Path x:Name="chk" Data="M2,8 L7,13 L16,3" Stroke="White" StrokeThickness="2.2"
                    StrokeStartLineCap="Round" StrokeEndLineCap="Round" Stretch="Uniform"
                    Margin="3" Opacity="0" />
            </Border>
            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" />
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="box" Property="Background" Value="{DynamicResource X.Brush.AccentGrad}" />
              <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
              <Setter TargetName="chk" Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.5" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style TargetType="CheckBox" BasedOn="{StaticResource X.CheckBox}" />

  <!-- RadioButton -->
  <Style x:Key="X.RadioButton" TargetType="RadioButton">
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
    <Setter Property="FontFamily" Value="{StaticResource X.Font.Ui}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Padding" Value="0,4" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <StackPanel Orientation="Horizontal">
            <Grid Width="18" Height="18" VerticalAlignment="Center">
              <Ellipse x:Name="outer" Stroke="{DynamicResource X.Brush.GlassBorder}" StrokeThickness="1"
                       Fill="{DynamicResource X.Brush.GlassFill}" />
              <Ellipse x:Name="dot" Width="9" Height="9" Fill="{DynamicResource X.Brush.AccentGrad}" Opacity="0" />
            </Grid>
            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" />
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="outer" Property="Stroke" Value="{DynamicResource X.Brush.Accent}" />
              <Setter TargetName="dot" Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="outer" Property="Stroke" Value="{DynamicResource X.Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.5" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style TargetType="RadioButton" BasedOn="{StaticResource X.RadioButton}" />

  <!-- ComboBox: стеклянная плашка + стрелка вниз. -->
  <ControlTemplate x:Key="X.ComboBox.ToggleTpl" TargetType="ToggleButton">
    <Border x:Name="bd" Background="{DynamicResource X.Brush.GlassFill}"
            BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1" CornerRadius="10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ContentPresenter Grid.Column="0" Margin="10,0,0,0" VerticalAlignment="Center" />
        <Path Grid.Column="1" Margin="8,0,12,0" VerticalAlignment="Center"
              Data="M0,0 L4,4 L8,0 Z" Fill="{DynamicResource X.Brush.TextSoft}" />
      </Grid>
    </Border>
    <ControlTemplate.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
      </Trigger>
      <Trigger Property="IsChecked" Value="True">
        <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style x:Key="X.ComboBoxItem" TargetType="ComboBoxItem">
    <Setter Property="Padding" Value="10,7" />
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
            <ContentPresenter />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource X.Brush.AccentTint}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="X.ComboBox" TargetType="ComboBox">
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
    <Setter Property="FontFamily" Value="{StaticResource X.Font.Ui}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Height" Value="36" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="ItemContainerStyle" Value="{StaticResource X.ComboBoxItem}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <ToggleButton x:Name="PART_Toggle" Focusable="False"
                          Template="{StaticResource X.ComboBox.ToggleTpl}"
                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
              <ContentPresenter x:Name="PART_ContentSite"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                IsHitTestVisible="False"
                                Margin="4,0,0,0" VerticalAlignment="Center" />
            </ToggleButton>
            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
              <Border Background="{DynamicResource X.Brush.GlassFillStrong}"
                      BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1"
                      CornerRadius="10" MinWidth="{TemplateBinding ActualWidth}" Margin="0,4,0,0">
                <Border.Effect>
                  <DropShadowEffect Color="#000" BlurRadius="18" ShadowDepth="0" Opacity="0.45" />
                </Border.Effect>
                <ScrollViewer MaxHeight="260">
                  <ItemsPresenter />
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style TargetType="ComboBox" BasedOn="{StaticResource X.ComboBox}" />

  <!-- Search box: плоский textbox без рамки/бэкграунда, рендерится поверх
       Border'а который держит сам piшешт (см. ServersView.xaml). -->
  <Style x:Key="X.SearchBox" TargetType="TextBox">
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
    <Setter Property="CaretBrush" Value="{DynamicResource X.Brush.Accent}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource X.Brush.Accent}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Grid>
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" Focusable="False"
                          VerticalAlignment="Center" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" />
            <TextBlock x:Name="ph" Text="Введите текст для поиска"
                       Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="13"
                       VerticalAlignment="Center" IsHitTestVisible="False"
                       Visibility="Collapsed" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Text" Value="">
              <Setter TargetName="ph" Property="Visibility" Value="Visible" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- TextBox -->
  <Style x:Key="X.TextBox" TargetType="TextBox">
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
    <Setter Property="CaretBrush" Value="{DynamicResource X.Brush.Accent}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource X.Brush.Accent}" />
    <Setter Property="Background" Value="{DynamicResource X.Brush.GlassFill}" />
    <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.GlassBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="12"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" Focusable="False" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ListBoxItem с состоянием выбора. Компактный desktop-вариант:
       padding 8×6, margin 4 — на 500×760 видно 4-5 карточек ключей сразу. -->
  <Style x:Key="X.ListBoxItem" TargetType="ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,0,0,4" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border x:Name="bd" Background="{DynamicResource X.Brush.GlassFill}" CornerRadius="10"
                  BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1" Padding="8,6">
            <ContentPresenter />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource X.Brush.Outline}" />
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource X.Brush.SurfaceHi}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource X.Brush.SurfaceHi}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ListBox без рамки и с прозрачным фоном -->
  <Style x:Key="X.ListBox" TargetType="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    <Setter Property="ItemContainerStyle" Value="{StaticResource X.ListBoxItem}" />
  </Style>

  <!-- ============================================================
       Neo-morphism / Brushed-metal / Grain / Ray-traced shadows.
       ============================================================ -->

  <!-- Процедурный тайл-шум поверх поверхностей: убирает бандинг в градиентах,
       даёт "аналоговый" look. Tileable 128×128 RGBA (белый RGB + переменная alpha). -->
  <ImageBrush x:Key="X.Brush.GrainOverlay"
              ImageSource="pack://application:,,,/Assets/Textures/Noise.png"
              TileMode="Tile" ViewportUnits="Absolute" Viewport="0,0,128,128"
              Stretch="None" Opacity="0.06" />

  <!-- Шлифованный алюминий: анизотропный горизонтальный градиент + шум поверх.
       Используется для sidebar-rail / Settings-панелей. -->
  <LinearGradientBrush x:Key="X.Brush.BrushedMetal" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="{DynamicResource X.Color.Surface}"    Offset="0" />
    <GradientStop Color="{DynamicResource X.Color.CanvasMid}"  Offset="0.18" />
    <GradientStop Color="{DynamicResource X.Color.Surface}"    Offset="0.38" />
    <GradientStop Color="{DynamicResource X.Color.SurfaceHi}"  Offset="0.62" />
    <GradientStop Color="{DynamicResource X.Color.Surface}"    Offset="0.82" />
    <GradientStop Color="{DynamicResource X.Color.CanvasMid}"  Offset="1" />
  </LinearGradientBrush>

  <!-- Горизонтальные царапины-штрихи (imagine brushed-metal finish). -->
  <ImageBrush x:Key="X.Brush.BrushedScratches"
              ImageSource="pack://application:,,,/Assets/Textures/BrushedMetal.png"
              TileMode="Tile" ViewportUnits="Absolute" Viewport="0,0,128,16"
              Stretch="None" Opacity="0.55" />

  <!-- Sidebar-rail: стекл комбинация — metal gradient + горизонт штрихи + шум. -->
  <Style x:Key="X.Panel.BrushedMetal" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource X.Brush.BrushedMetal}" />
    <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.GlassBorder}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <!-- Матовое стекло контент-панели (использует системный Acrylic/Mica под собой +
       локальный frost слой). 30px blur — системный; локально добавляем lighter fill. -->
  <Style x:Key="X.Panel.FrostedGlass" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource X.Brush.GlassFill}" />
    <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.GlassBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <!-- Неоморфная карточка: Inner sheen (верх-лево белый) + ambient shadow (низ-право тёмный)
       имитирует "приподнятый" элемент. Два встречных DropShadowEffect нельзя, но можно
       через Border+Border стек: первый — тёмная тень, второй — светлый блик. -->
  <Style x:Key="X.Card.Neuro" TargetType="Border" BasedOn="{StaticResource X.Card}">
    <Setter Property="Background" Value="{DynamicResource X.Brush.GlassFillStrong}" />
    <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.GlassBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect Color="{DynamicResource X.Color.GlassShadow}"
                          BlurRadius="24" ShadowDepth="6" Direction="270" Opacity="0.55" />
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       Custom ScrollBar — стеклянный, без стрелок.
       ============================================================ -->
  <Style x:Key="X.ScrollBarThumb" TargetType="Thumb">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border CornerRadius="4" Margin="2"
                  Background="{DynamicResource X.Brush.GlassFillStrong}"
                  BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Style.Triggers>
      <Trigger Property="Orientation" Value="Vertical">
        <Setter Property="Width" Value="10" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Grid Background="Transparent">
                <Track Name="PART_Track" IsDirectionReversed="True">
                  <Track.Thumb>
                    <Thumb Style="{StaticResource X.ScrollBarThumb}" />
                  </Track.Thumb>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Trigger>
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Height" Value="10" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Grid Background="Transparent">
                <Track Name="PART_Track">
                  <Track.Thumb>
                    <Thumb Style="{StaticResource X.ScrollBarThumb}" />
                  </Track.Thumb>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ============================================================
       FAQ-card Expander (стиль iOS-карточки как в Happ 2.9.0):
       вопрос — закруглённая карточка 14px с chevron ⌄ справа,
       по клику раскрывается ответ внутри (Margin=14,0,14,12).
       ============================================================ -->
  <Style x:Key="X.Expander.FaqCard" TargetType="Expander">
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
    <Setter Property="Background" Value="{DynamicResource X.Brush.GlassFill}" />
    <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.GlassBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Expander">
          <Border x:Name="card" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="14">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Header: question + chevron -->
              <ToggleButton x:Name="HeaderSite" Grid.Row="0"
                            IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                            Background="Transparent" BorderThickness="0" Padding="14,12"
                            HorizontalContentAlignment="Stretch" Cursor="Hand"
                            Focusable="False">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Grid Background="Transparent">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ContentPresenter Grid.Column="0" Content="{TemplateBinding Content}"
                                        VerticalAlignment="Center"
                                        TextBlock.Foreground="{DynamicResource X.Brush.Text}"
                                        TextBlock.FontSize="13"
                                        TextBlock.FontWeight="Medium" />
                      <TextBlock x:Name="chev" Grid.Column="1" Text="⌄"
                                 FontSize="18" Foreground="{DynamicResource X.Brush.TextSoft}"
                                 VerticalAlignment="Center" Margin="10,0,2,0">
                        <TextBlock.RenderTransform>
                          <RotateTransform Angle="0" CenterX="6" CenterY="9" />
                        </TextBlock.RenderTransform>
                      </TextBlock>
                    </Grid>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsChecked" Value="True">
                        <Trigger.EnterActions>
                          <BeginStoryboard>
                            <Storyboard>
                              <DoubleAnimation Storyboard.TargetName="chev"
                                               Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                               To="180" Duration="0:0:0.18" />
                            </Storyboard>
                          </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                          <BeginStoryboard>
                            <Storyboard>
                              <DoubleAnimation Storyboard.TargetName="chev"
                                               Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                               To="0" Duration="0:0:0.18" />
                            </Storyboard>
                          </BeginStoryboard>
                        </Trigger.ExitActions>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" />
              </ToggleButton>

              <!-- Body -->
              <ContentPresenter x:Name="ExpandSite" Grid.Row="1" Margin="14,0,14,12"
                                Visibility="Collapsed" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsExpanded" Value="True">
              <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
              <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="card" Property="Background" Value="{DynamicResource X.Brush.GlassFillStrong}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       Enhanced Ghost button с внутренним highlight на hover.
       Применяется поверх базового X.Btn.Ghost через attached CursorLight
       behavior (см. Ui/CursorLight.cs).
       ============================================================ -->
  <Style x:Key="X.Btn.Ghost.Neo" TargetType="Button" BasedOn="{StaticResource X.Btn.Ghost}">
    <Setter Property="ui:CursorLight.Enabled" Value="True" />
  </Style>

</ResourceDictionary>
