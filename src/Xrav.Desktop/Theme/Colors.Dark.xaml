<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Тёмная палитра (по умолчанию) -->
  <Color x:Key="X.Color.Canvas">#FF0B0C16</Color>
  <Color x:Key="X.Color.CanvasMid">#FF12131F</Color>
  <Color x:Key="X.Color.Surface">#FF181A2B</Color>
  <Color x:Key="X.Color.SurfaceHi">#FF20243B</Color>
  <Color x:Key="X.Color.Outline">#22FFFFFF</Color>
  <Color x:Key="X.Color.OutlineSoft">#11FFFFFF</Color>

  <Color x:Key="X.Color.Accent">#FF7C5CFF</Color>
  <Color x:Key="X.Color.Accent2">#FF18BFFF</Color>
  <Color x:Key="X.Color.Success">#FF00D4A0</Color>
  <Color x:Key="X.Color.Warn">#FFFFB547</Color>
  <Color x:Key="X.Color.Danger">#FFFF4D6D</Color>

  <Color x:Key="X.Color.Text">#FFEDF0F7</Color>
  <Color x:Key="X.Color.TextSoft">#CCBFC5D4</Color>
  <Color x:Key="X.Color.TextMuted">#B0BAC0D2</Color>

  <!-- Декоративные цвета фона -->
  <Color x:Key="X.Color.BgGlow1">#FF7C5CFF</Color>
  <Color x:Key="X.Color.BgGlow2">#FF18BFFF</Color>
  <Color x:Key="X.Color.BgGrad1">#FF0B0C16</Color>
  <Color x:Key="X.Color.BgGrad2">#FF13142A</Color>
  <Color x:Key="X.Color.BgGrad3">#FF0B0C16</Color>

  <!-- Полупрозрачные тени для banner'ов -->
  <Color x:Key="X.Color.DangerTint">#22FF4D6D</Color>
  <Color x:Key="X.Color.WarnTint">#22FFB547</Color>
  <Color x:Key="X.Color.AccentTint">#227C5CFF</Color>

  <!-- Liquid Glass (iOS 26 / Vision Pro): полупрозрачные слои -->
  <Color x:Key="X.Color.GlassFill">#33FFFFFF</Color>
  <Color x:Key="X.Color.GlassFillStrong">#4DFFFFFF</Color>
  <Color x:Key="X.Color.GlassBorder">#55FFFFFF</Color>
  <Color x:Key="X.Color.GlassHighlight">#1FFFFFFF</Color>
  <Color x:Key="X.Color.GlassShadow">#80000000</Color>

  <!-- Power-button gradients -->
  <Color x:Key="X.Color.PowerOff1">#22202A4A</Color>
  <Color x:Key="X.Color.PowerOff2">#0E0E1224</Color>
  <Color x:Key="X.Color.PowerOff3">#000B0C16</Color>
  <Color x:Key="X.Color.PowerOn1">#557C5CFF</Color>
  <Color x:Key="X.Color.PowerOn2">#3318BFFF</Color>
  <Color x:Key="X.Color.PowerOn3">#000B0C16</Color>
</ResourceDictionary>
