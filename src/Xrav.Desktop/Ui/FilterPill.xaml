<UserControl x:Class="Xrav.Desktop.Ui.FilterPill"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Self"
             Background="Transparent">
  <Button x:Name="Btn" Cursor="Hand" Margin="0,0,8,0"
          Command="{Binding Command, ElementName=Self}"
          CommandParameter="{Binding FilterValue, ElementName=Self}">
    <Button.Template>
      <ControlTemplate TargetType="Button">
        <Border x:Name="bd" CornerRadius="14" Padding="12,6"
                Background="{DynamicResource X.Brush.GlassFill}"
                BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1">
          <TextBlock x:Name="Lbl" Text="{Binding Label, ElementName=Self}"
                     FontSize="12" FontWeight="SemiBold"
                     Foreground="{DynamicResource X.Brush.Text}"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="180" />
        </Border>
        <ControlTemplate.Triggers>
          <DataTrigger Value="True">
            <DataTrigger.Binding>
              <MultiBinding Converter="{StaticResource StrEqualsConverter}">
                <Binding Path="Active" ElementName="Self" />
                <Binding Path="FilterValue" ElementName="Self" />
              </MultiBinding>
            </DataTrigger.Binding>
            <Setter TargetName="bd" Property="Background" Value="{DynamicResource X.Brush.AccentGrad}" />
            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
            <Setter TargetName="Lbl" Property="Foreground" Value="White" />
          </DataTrigger>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
          </Trigger>
        </ControlTemplate.Triggers>
      </ControlTemplate>
    </Button.Template>
  </Button>
</UserControl>
