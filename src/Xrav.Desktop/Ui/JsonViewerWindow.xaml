<Window x:Class="Xrav.Desktop.Ui.JsonViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JSON конфиг"
        Height="600" Width="780"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource X.Brush.Bg}"
        TextOptions.TextFormattingMode="Display">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,10">
      <TextBlock x:Name="TitleText" Style="{StaticResource X.Text.H2}" TextTrimming="CharacterEllipsis" />
      <TextBlock x:Name="KindText" Style="{StaticResource X.Text.Caption}" Margin="0,2,0,0" />
    </StackPanel>

    <Border Grid.Row="1" Background="{StaticResource X.Brush.Surface}"
            BorderBrush="{StaticResource X.Brush.OutlineSoft}" BorderThickness="1" CornerRadius="10">
      <TextBox x:Name="JsonBox" IsReadOnly="True"
               BorderThickness="0" Padding="10"
               FontFamily="Consolas, Courier New, monospace" FontSize="12"
               Background="Transparent"
               Foreground="{DynamicResource X.Brush.Text}"
               TextWrapping="NoWrap"
               VerticalScrollBarVisibility="Auto"
               HorizontalScrollBarVisibility="Auto"
               AcceptsReturn="True" />
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="Скопировать" Click="OnCopyClick" Style="{StaticResource X.Btn.Ghost}" Margin="0,0,8,0" />
      <Button Content="Сохранить как файл…" Click="OnSaveClick" Style="{StaticResource X.Btn.Ghost}" Margin="0,0,8,0" />
      <Button Content="Закрыть" Click="OnCloseClick" Style="{StaticResource X.Btn.Primary}" />
    </StackPanel>
  </Grid>
</Window>
