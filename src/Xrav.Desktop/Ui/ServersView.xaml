<UserControl x:Class="Xrav.Desktop.Ui.ServersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:Xrav.Desktop.Ui"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="500">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <ui:SubscriptionFilterMatchConverter x:Key="FilterMatch" />
  </UserControl.Resources>
  <Grid Margin="20,4,20,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="Серверы" Style="{StaticResource X.Text.H2}" />
        <TextBlock Style="{StaticResource X.Text.Caption}" TextWrapping="Wrap" Margin="0,2,0,0"
                   Text="Smart-режим включён: приложение само подбирает оптимальный ключ из подписок и автоматически переключается при сбое сети."
                   Visibility="{Binding SmartOnly, Converter={StaticResource BoolToVisHelper}}" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
        <Button Content="Пинг всех" Command="{Binding PingAllKeysCommand}" Style="{StaticResource X.Btn.Ghost}" Margin="0,0,8,0"
                Visibility="{Binding SmartOnly, Converter={StaticResource InverseBoolToVis}}" />
        <Border Style="{StaticResource X.Badge.Pill}">
          <TextBlock Text="{Binding FilteredKeys.Count, StringFormat={}{0} ключей}" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="11" />
        </Border>
      </StackPanel>
    </Grid>

    <!-- Фильтр-пилюли по подпискам -->
    <Border Grid.Row="1" Margin="0,12,0,0"
            Visibility="{Binding HasSubscriptions, Converter={StaticResource BoolToVisHelper}}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal">
          <ui:FilterPill Label="Все" FilterValue="@all"
                         Active="{Binding SubscriptionFilterEncoded}"
                         Command="{Binding SetSubscriptionFilterCommand}" />
          <ItemsControl ItemsSource="{Binding Subscriptions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <ui:FilterPill Label="{Binding Label}" FilterValue="{Binding Id}"
                               Active="{Binding DataContext.SubscriptionFilterEncoded, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Command="{Binding DataContext.SetSubscriptionFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Smart-режим: компактная карточка с информацией о выбранном ключе -->
    <Border Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource X.Card}"
            Visibility="{Binding SmartOnly, Converter={StaticResource BoolToVisHelper}}">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="✨" FontSize="18" Margin="0,0,8,0" />
          <TextBlock Text="Smart-режим" Foreground="{DynamicResource X.Brush.Text}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Margin="0,6,0,0" FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource X.Brush.TextSoft}"
                   Text="Жми кнопку питания — приложение само выберет ключ с лучшим пингом и при сбое (потеря пинга / handshake / обрыв соединения) мгновенно переключится на следующий рабочий ключ из подписки." />
        <TextBlock Margin="0,8,0,0" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource X.Brush.Accent2}"
                   Text="{Binding AutoStatusLine}" TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Border Grid.Row="3" Margin="0,12,0,0"
            Visibility="{Binding SmartOnly, Converter={StaticResource InverseBoolToVis}}">
      <ListBox ItemsSource="{Binding FilteredKeys}" SelectedItem="{Binding SelectedKey, Mode=TwoWay}" Style="{StaticResource X.ListBox}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                      Background="{DynamicResource X.Brush.AccentGrad}" VerticalAlignment="Center" Margin="0,0,12,0"
                      ClipToBounds="True" ToolTip="{Binding FlagEmoji}">
                <Grid>
                  <TextBlock Text="{Binding DisplayBadge}" Foreground="White" FontWeight="Bold"
                             FontFamily="Segoe UI" FontSize="15"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <Image Source="{Binding DisplayBadge, Converter={StaticResource FlagImage}}"
                         Stretch="UniformToFill" />
                </Grid>
              </Border>
              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Remark}" Foreground="{DynamicResource X.Brush.Text}"
                           FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource X.Brush.TextMuted}"
                           FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
              </StackPanel>
              <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource X.Badge.Pill}" Margin="6,0">
                  <TextBlock Text="{Binding LatencyDisplay}" FontSize="11"
                             Foreground="{DynamicResource X.Brush.TextSoft}" />
                </Border>
                <TextBlock Text="●" Foreground="{DynamicResource X.Brush.Accent}"
                           FontSize="14" VerticalAlignment="Center" Margin="4,0,4,0"
                           Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BoolToVis}}" />
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0"
                Visibility="{Binding SmartOnly, Converter={StaticResource InverseBoolToVis}}">
      <Button Content="Пинг" Command="{Binding PingSelectedKeyCommand}" Style="{StaticResource X.Btn.Ghost}" Margin="0,0,8,0"
              ToolTip="TCP-проверка доступности сервера" />
      <Button Content="Удалить" Command="{Binding RemoveSelectedKeyCommand}" Style="{StaticResource X.Btn.Danger}" />
    </StackPanel>
  </Grid>
</UserControl>
