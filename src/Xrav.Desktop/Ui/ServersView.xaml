<UserControl x:Class="Xrav.Desktop.Ui.ServersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:Xrav.Desktop.Ui"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="500">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <ui:SubscriptionFilterMatchConverter x:Key="FilterMatch" />

    <!-- Карточка ключа в стиле Happ 2.9.0: круглый флаг 32px,
         двустрочный текст "имя ключа / VLESS / WS / TLS",
         справа chevron `›`. На hover — подсветка фона. -->
    <DataTemplate x:Key="X.KeyItem.Template">
      <Grid Margin="0,0,4,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                Background="{DynamicResource X.Brush.AccentGrad}"
                VerticalAlignment="Center" Margin="0,0,12,0"
                ClipToBounds="True" ToolTip="{Binding FlagEmoji}">
          <Grid>
            <TextBlock Text="{Binding DisplayBadge}" Foreground="White" FontWeight="Bold"
                       FontFamily="Segoe UI" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
            <Image Source="{Binding DisplayBadge, Converter={StaticResource FlagImage}}"
                   Stretch="UniformToFill" />
          </Grid>
        </Border>
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock Text="{Binding Remark}" Foreground="{DynamicResource X.Brush.Text}"
                     FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding ProtocolStack}" Foreground="{DynamicResource X.Brush.TextMuted}"
                     FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding LatencyDisplay}" FontSize="11"
                   Foreground="{DynamicResource X.Brush.TextSoft}" VerticalAlignment="Center"
                   Margin="0,0,8,0"
                   Visibility="{Binding LatencyMs, Converter={StaticResource NullToVisCollapsed}}" />
        <TextBlock Grid.Column="3" Text="›" FontSize="20"
                   Foreground="{DynamicResource X.Brush.TextSoft}" VerticalAlignment="Center" />
      </Grid>
    </DataTemplate>
  </UserControl.Resources>
  <Grid Margin="20,0,20,6">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- ROW 0: заголовок + действия -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="Серверы" Style="{StaticResource X.Text.H2}" />
        <TextBlock Style="{StaticResource X.Text.Caption}" TextWrapping="Wrap" Margin="0,2,0,0"
                   Text="Smart-режим включён: приложение само подбирает оптимальный ключ из подписок и автоматически переключается при сбое сети."
                   Visibility="{Binding SmartOnly, Converter={StaticResource BoolToVisHelper}}" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"
                  Visibility="{Binding SmartOnly, Converter={StaticResource InverseBoolToVis}}">
        <Button Content="Пинг всех" Command="{Binding PingAllKeysCommand}" Style="{StaticResource X.Btn.Ghost}" Margin="0,0,8,0"
                ToolTip="TCP-проверка доступности всех серверов из списка" />
        <Button Content="Удалить" Command="{Binding RemoveSelectedKeyCommand}" Style="{StaticResource X.Btn.Danger}"
                ToolTip="Удалить выбранный ключ из списка" />
      </StackPanel>
    </Grid>

    <!-- ROW 1 (раньше тут было поле поиска — убрано по запросу) -->

    <!-- ROW 2: фильтр-пилюли по подпискам -->
    <Border Grid.Row="2" Margin="0,12,0,0"
            Visibility="{Binding HasSubscriptions, Converter={StaticResource BoolToVisHelper}}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal">
          <ui:FilterPill Label="Все" FilterValue="@all"
                         Active="{Binding SubscriptionFilterEncoded}"
                         Command="{Binding SetSubscriptionFilterCommand}" />
          <ItemsControl ItemsSource="{Binding Subscriptions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <ui:FilterPill Label="{Binding Label}" FilterValue="{Binding Id}"
                               Active="{Binding DataContext.SubscriptionFilterEncoded, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Command="{Binding DataContext.SetSubscriptionFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ROW 3: Smart-режим: компактная карточка -->
    <Border Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource X.Card}"
            Visibility="{Binding SmartOnly, Converter={StaticResource BoolToVisHelper}}">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="✨" FontSize="18" Margin="0,0,8,0" />
          <TextBlock Text="Smart-режим" Foreground="{DynamicResource X.Brush.Text}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Margin="0,6,0,0" FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource X.Brush.TextSoft}"
                   Text="Жми кнопку питания — приложение само выберет ключ с лучшим пингом и при сбое (потеря пинга / handshake / обрыв соединения) мгновенно переключится на следующий рабочий ключ из подписки." />
        <TextBlock Margin="0,8,0,0" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource X.Brush.Accent2}"
                   Text="{Binding AutoStatusLine}" TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <!-- ROW 4: список ключей сгруппированных по подпискам -->
    <ScrollViewer Grid.Row="4" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Visibility="{Binding SmartOnly, Converter={StaticResource InverseBoolToVis}}">
      <ItemsControl ItemsSource="{Binding KeyGroups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,10"
                    Background="{DynamicResource X.Brush.GlassFill}"
                    BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="0">
              <StackPanel>
                <!-- Заголовок группы: домен подписки + дата обновления + кол-во -->
                <Border Padding="14,10" CornerRadius="14,14,0,0"
                        Background="{DynamicResource X.Brush.GlassFillStrong}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Label}" Foreground="{DynamicResource X.Brush.Text}"
                                 FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding LastUpdate}" Foreground="{DynamicResource X.Brush.TextSoft}"
                                 FontSize="11" Margin="0,2,0,0"
                                 Visibility="{Binding LastUpdate, Converter={StaticResource StringToVisCollapsed}}" />
                    </StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource X.Badge.Pill}" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Count}" FontSize="11"
                                 Foreground="{DynamicResource X.Brush.TextSoft}" />
                    </Border>
                  </Grid>
                </Border>

                <!-- Тонкий разделитель header / body -->
                <Border Height="1" Background="{DynamicResource X.Brush.GlassBorder}" />

                <!-- Список ключей внутри группы. ScrollViewer.CanContentScroll=False
                     отключает виртуализацию — высота каждого ключа невелика и список
                     короткий, виртуализация не нужна, зато снимаем перехват MouseWheel
                     внутренним ScrollViewer'ом ListBox'а. Дополнительно прокидываем
                     PreviewMouseWheel в code-behind, чтобы внешний ScrollViewer всегда
                     получал событие колеса. -->
                <ListBox ItemsSource="{Binding Keys}"
                         SelectedItem="{Binding DataContext.SelectedKey, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                         Style="{StaticResource X.ListBox}"
                         BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="False"
                         PreviewMouseWheel="GroupListBox_PreviewMouseWheel"
                         ItemTemplate="{StaticResource X.KeyItem.Template}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
