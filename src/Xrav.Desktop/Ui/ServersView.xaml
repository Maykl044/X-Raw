<UserControl x:Class="Xrav.Desktop.Ui.ServersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="500">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </UserControl.Resources>
  <Grid Margin="20,4,20,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="Серверы" Style="{StaticResource X.Text.H2}" />
        <TextBlock Style="{StaticResource X.Text.Caption}" TextWrapping="Wrap" Margin="0,2,0,0"
                   Text="Один ключ: vless:// / vmess:// / trojan:// / ss:// / hy2:// / tuic://. Подписки управляются на вкладке «Подписка»." />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
        <Button Content="Пинг всех" Command="{Binding PingAllKeysCommand}" Style="{StaticResource X.Btn.Ghost}" Margin="0,0,8,0" />
        <Border Background="{DynamicResource X.Brush.GlassFill}" CornerRadius="10"
                BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1" Padding="10,4" VerticalAlignment="Center">
          <TextBlock Text="{Binding Keys.Count, StringFormat={}{0} ключей}" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="11" />
        </Border>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" Margin="0,12,0,0" Background="{DynamicResource X.Brush.GlassFill}"
            BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1" CornerRadius="14" Padding="10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox Grid.Column="0" Text="{Binding ManualKeyText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource X.TextBox}"
                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40" MaxHeight="100"
                 VerticalScrollBarVisibility="Auto"
                 ToolTip="vless://… или vmess://… (поддерживается несколько строк сразу)" />
        <StackPanel Grid.Column="1" Margin="8,0,0,0" Orientation="Vertical">
          <Button Content="Добавить" Command="{Binding AddManualKeyCommand}" Style="{StaticResource X.Btn.Primary}" Margin="0,0,0,6" />
          <Button Content="Из буфера" Command="{Binding ImportFromClipboardCommand}" Style="{StaticResource X.Btn.Ghost}" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="2" Margin="0,12,0,0">
      <ListBox ItemsSource="{Binding Keys}" SelectedItem="{Binding SelectedKey, Mode=TwoWay}" Style="{StaticResource X.ListBox}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                      Background="{DynamicResource X.Brush.AccentGrad}" VerticalAlignment="Center" Margin="0,0,12,0">
                <TextBlock Text="{Binding ShortProtocolLabel}" Foreground="White" FontWeight="Bold"
                           FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Remark}" Foreground="{DynamicResource X.Brush.Text}"
                           FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource X.Brush.TextMuted}"
                           FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
              </StackPanel>
              <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Border CornerRadius="8" Padding="8,3" Margin="6,0"
                        Background="{DynamicResource X.Brush.GlassFill}"
                        BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1">
                  <TextBlock Text="{Binding LatencyDisplay}" FontSize="11"
                             Foreground="{DynamicResource X.Brush.TextSoft}" />
                </Border>
                <TextBlock Text="●" Foreground="{DynamicResource X.Brush.Accent}"
                           FontSize="14" VerticalAlignment="Center" Margin="4,0,4,0"
                           Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BoolToVis}}" />
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="Пинг" Command="{Binding PingSelectedKeyCommand}" Style="{StaticResource X.Btn.Ghost}" Margin="0,0,8,0"
              ToolTip="TCP-проверка доступности сервера" />
      <Button Content="Рукопожатие" Command="{Binding CheckHandshakeCommand}" Style="{StaticResource X.Btn.Ghost}" Margin="0,0,8,0"
              ToolTip="Реальная проверка TLS / Reality / SNI рукопожатия с сервером ключа" />
      <Button Content="Удалить выбранный" Command="{Binding RemoveSelectedKeyCommand}" Style="{StaticResource X.Btn.Danger}" />
    </StackPanel>
  </Grid>
</UserControl>
