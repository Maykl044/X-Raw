<UserControl x:Class="Xrav.Desktop.Ui.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:storage="clr-namespace:Xrav.Desktop.Storage"
             xmlns:loc="clr-namespace:Xrav.Desktop.Localization"
             x:Name="rootView"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="500">
  <UserControl.Resources>
    <!-- Settings menu row: компактный desktop-бар. Слева — цветная иконка,
         центр — заголовок + подзаголовок, справа — chevron. На hover —
         плавная подсветка фона + лёгкое смещение chevron вправо. -->
    <Style x:Key="X.Settings.MenuRow" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource X.Brush.GlassFill}" />
      <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.GlassBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource X.Brush.Text}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Emoji, Segoe UI Symbol" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="14" Padding="{TemplateBinding Padding}">
              <ContentPresenter VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{DynamicResource X.Brush.GlassFillStrong}" />
                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{DynamicResource X.Brush.SurfaceHi}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Иконка-бейдж в начале строки меню (мини-аватар секции) -->
    <Style x:Key="X.Settings.IconBadge" TargetType="Border">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,12,0" />
      <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.GlassBorder}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="X.Settings.IconGlyph" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI Symbol, Segoe UI" />
    </Style>
  </UserControl.Resources>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="20,0,20,6" TextOptions.TextFormattingMode="Display">
      <Grid.Resources>
        <Style TargetType="TextBlock">
          <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Emoji, Segoe UI Symbol" />
        </Style>
      </Grid.Resources>

      <!-- ======= MENU (главный экран Настроек) ======= -->
      <StackPanel x:Name="PageMenu">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ElementName=rootView, Path=Page}" Value="menu">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <TextBlock Text="{loc:T settings.title}" Style="{StaticResource X.Text.H2}" Margin="0,0,0,10" />

        <Button Style="{StaticResource X.Settings.MenuRow}" Tag="appearance" Click="OnMenuClick">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource X.Settings.IconBadge}" Background="{DynamicResource X.Brush.AccentGrad}">
              <TextBlock Text="🎨" Style="{StaticResource X.Settings.IconGlyph}" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="Внешний вид" FontWeight="SemiBold" FontSize="14" />
              <TextBlock Text="Тема оформления, язык интерфейса" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock Grid.Column="2" Text="›" FontSize="22" Foreground="{DynamicResource X.Brush.TextSoft}" VerticalAlignment="Center" Margin="8,0,0,0" />
          </Grid>
        </Button>

        <Button Style="{StaticResource X.Settings.MenuRow}" Tag="mode" Click="OnMenuClick">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource X.Settings.IconBadge}" Background="{DynamicResource X.Brush.GreenGrad}">
              <TextBlock Text="✨" Style="{StaticResource X.Settings.IconGlyph}" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="Режим подключения" FontWeight="SemiBold" FontSize="14" />
              <TextBlock Text="Smart-режим и ручной выбор ключей" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock Grid.Column="2" Text="›" FontSize="22" Foreground="{DynamicResource X.Brush.TextSoft}" VerticalAlignment="Center" Margin="8,0,0,0" />
          </Grid>
        </Button>

        <Button Style="{StaticResource X.Settings.MenuRow}" Tag="bypass" Click="OnMenuClick">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource X.Settings.IconBadge}" Background="{DynamicResource X.Brush.AmberGrad}">
              <TextBlock Text="🛡" Style="{StaticResource X.Settings.IconGlyph}" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="Обход блокировок" FontWeight="SemiBold" FontSize="14" />
              <TextBlock Text="Фрагментация TLS, mux-конвейер, шумовые пакеты" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock Grid.Column="2" Text="›" FontSize="22" Foreground="{DynamicResource X.Brush.TextSoft}" VerticalAlignment="Center" Margin="8,0,0,0" />
          </Grid>
        </Button>

        <Button Style="{StaticResource X.Settings.MenuRow}" Tag="faq" Click="OnMenuClick">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource X.Settings.IconBadge}" Background="{DynamicResource X.Brush.GlassFillStrong}">
              <TextBlock Text="❔" Style="{StaticResource X.Settings.IconGlyph}" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="Справка и FAQ" FontWeight="SemiBold" FontSize="14" />
              <TextBlock Text="Ответы на частые вопросы о работе клиента" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock Grid.Column="2" Text="›" FontSize="22" Foreground="{DynamicResource X.Brush.TextSoft}" VerticalAlignment="Center" Margin="8,0,0,0" />
          </Grid>
        </Button>

        <Button Style="{StaticResource X.Settings.MenuRow}" Tag="about" Click="OnMenuClick">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource X.Settings.IconBadge}" Background="{DynamicResource X.Brush.PurpleGrad}">
              <TextBlock Text="ℹ" Style="{StaticResource X.Settings.IconGlyph}" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="О приложении" FontWeight="SemiBold" FontSize="14" />
              <TextBlock Text="Версия, лицензия, контакты проекта" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock Grid.Column="2" Text="›" FontSize="22" Foreground="{DynamicResource X.Brush.TextSoft}" VerticalAlignment="Center" Margin="8,0,0,0" />
          </Grid>
        </Button>
      </StackPanel>

      <!-- ======= APPEARANCE ======= -->
      <StackPanel x:Name="PageAppearance">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ElementName=rootView, Path=Page}" Value="appearance">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Left" Style="{StaticResource X.Btn.Ghost}" Content="‹  Назад" Click="OnBackClick" />
          <TextBlock Text="{loc:T settings.appearance}" Style="{StaticResource X.Text.H2}" Margin="14,0,0,0" VerticalAlignment="Center" />
        </DockPanel>

        <Border Background="{DynamicResource X.Brush.GlassFill}" BorderBrush="{DynamicResource X.Brush.GlassBorder}"
                BorderThickness="1" CornerRadius="14" Padding="14">
          <StackPanel>
            <TextBlock Style="{StaticResource X.Text.Caption}" Margin="0,0,0,4" Text="{loc:T settings.theme}" />
            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding SelectedThemeCode, Mode=TwoWay}">
              <ComboBoxItem Tag="light"  Content="{loc:T settings.theme.light}" />
              <ComboBoxItem Tag="dark"   Content="{loc:T settings.theme.dark}" />
              <ComboBoxItem Tag="system" Content="{loc:T settings.theme.system}" />
            </ComboBox>

            <TextBlock Style="{StaticResource X.Text.Caption}" Margin="0,14,0,4" Text="{loc:T settings.language}" />
            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay}">
              <ComboBoxItem Tag="ru" Content="Русский" />
              <ComboBoxItem Tag="en" Content="English" />
              <ComboBoxItem Tag="tr" Content="Türkçe" />
            </ComboBox>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ======= MODE ======= -->
      <StackPanel x:Name="PageMode">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ElementName=rootView, Path=Page}" Value="mode">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Left" Style="{StaticResource X.Btn.Ghost}" Content="‹  Назад" Click="OnBackClick" />
          <TextBlock Text="{loc:T settings.mode}" Style="{StaticResource X.Text.H2}" Margin="14,0,0,0" VerticalAlignment="Center" />
        </DockPanel>

        <Border Background="{DynamicResource X.Brush.GlassFill}" BorderBrush="{DynamicResource X.Brush.GlassBorder}"
                BorderThickness="1" CornerRadius="14" Padding="14">
          <StackPanel>
            <TextBlock Style="{StaticResource X.Text.Caption}" TextWrapping="Wrap" Margin="0,0,0,8"
                       Text="{loc:T settings.autoHint}" />
            <RadioButton GroupName="mode_xrav" Content="{loc:T settings.mode.manual}"
                         IsChecked="{Binding IsManualMode, Mode=OneWay}" Foreground="{DynamicResource X.Brush.Text}"
                         Margin="0,0,0,4">
              <RadioButton.Style>
                <Style TargetType="RadioButton">
                  <EventSetter Event="Checked" Handler="OnManualChecked" />
                </Style>
              </RadioButton.Style>
            </RadioButton>
            <RadioButton GroupName="mode_xrav" Content="{loc:T settings.mode.auto}"
                         IsChecked="{Binding AutoSelectMode, Mode=TwoWay}" Foreground="{DynamicResource X.Brush.Text}" />
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ======= BYPASS (Обход блокировок) ======= -->
      <StackPanel x:Name="PageBypass">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ElementName=rootView, Path=Page}" Value="bypass">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Left" Style="{StaticResource X.Btn.Ghost}" Content="‹  Назад" Click="OnBackClick" />
          <TextBlock Text="Обход блокировок" Style="{StaticResource X.Text.H2}" Margin="14,0,0,0" VerticalAlignment="Center" />
        </DockPanel>

        <Border Background="{DynamicResource X.Brush.GlassFill}" BorderBrush="{DynamicResource X.Brush.GlassBorder}"
                BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock Style="{StaticResource X.Text.Caption}" TextWrapping="Wrap" Margin="0,0,0,10"
                       Text="Универсальные настройки для всех TLS/REALITY ключей. Помогают пройти DPI, который блокирует SNI или замедляет handshake. Применяется автоматически после сохранения." />

            <CheckBox x:Name="ChkFragment" Content="Фрагментация TLS-ClientHello (рекомендуется)"
                      Foreground="{DynamicResource X.Brush.Text}" FontWeight="SemiBold"
                      Click="OnBypassChanged" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="11" Margin="0,0,0,12"
                       Text="Делит ClientHello на куски длины 10–20 байт с интервалом 10–20 мс. DPI не успевает прочитать SNI и пропускает пакет." />

            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Style="{StaticResource X.Text.Caption}" Text="Длина пакета (мин-макс)" />
                <TextBox x:Name="TxtFragLen" Style="{StaticResource X.TextBox}" TextChanged="OnBypassChanged" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Style="{StaticResource X.Text.Caption}" Text="Интервал, мс (мин-макс)" />
                <TextBox x:Name="TxtFragInt" Style="{StaticResource X.TextBox}" TextChanged="OnBypassChanged" />
              </StackPanel>
            </Grid>

            <CheckBox x:Name="ChkMux" Content="Mux.cool — мультиплекс соединений"
                      Foreground="{DynamicResource X.Brush.Text}" FontWeight="SemiBold"
                      Click="OnBypassChanged" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="11" Margin="0,0,0,12"
                       Text="До 8 одновременных потоков в одном TCP-канале. Ускоряет загрузку и затрудняет DPI-эвристики." />

            <CheckBox x:Name="ChkNoise" Content="Шумовой трафик (экспериментально)"
                      Foreground="{DynamicResource X.Brush.Text}" FontWeight="SemiBold"
                      Click="OnBypassChanged" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="11" Margin="0,0,0,12"
                       Text="Случайные пакеты до handshake. Может помочь, когда DPI блокирует по таймингу. Включайте только если базовая фрагментация не работает." />

            <Button Content="Сбросить к рекомендованным"
                    Style="{StaticResource X.Btn.Ghost}" Click="OnBypassResetClick" HorizontalAlignment="Left" />
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ======= URL SCHEME ======= -->
      <StackPanel x:Name="PageUrl">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ElementName=rootView, Path=Page}" Value="url">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Left" Style="{StaticResource X.Btn.Ghost}" Content="‹  Назад" Click="OnBackClick" />
          <TextBlock Text="{loc:T settings.url}" Style="{StaticResource X.Text.H2}" Margin="14,0,0,0" VerticalAlignment="Center" />
        </DockPanel>

        <Border Background="{DynamicResource X.Brush.GlassFill}" BorderBrush="{DynamicResource X.Brush.GlassBorder}"
                BorderThickness="1" CornerRadius="14" Padding="14">
          <StackPanel>
            <TextBlock Style="{StaticResource X.Text.Caption}" TextWrapping="Wrap" Margin="0,0,0,8"
                       Text="{loc:T settings.urlCaption}" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Button Grid.Column="0" Content="{loc:T settings.urlRegister}" Command="{Binding RegisterUrlSchemeCommand}"
                      Style="{StaticResource X.Btn.Primary}" />
              <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                         Text="{loc:T settings.urlRegistered}"
                         Foreground="{DynamicResource X.Brush.Success}" FontWeight="SemiBold" FontSize="12"
                         Visibility="{Binding UrlSchemeRegistered, Converter={StaticResource BoolToVisHelper}}" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ======= TOOLS ======= -->
      <StackPanel x:Name="PageTools">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ElementName=rootView, Path=Page}" Value="tools">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Left" Style="{StaticResource X.Btn.Ghost}" Content="‹  Назад" Click="OnBackClick" />
          <TextBlock Text="{loc:T settings.tools}" Style="{StaticResource X.Text.H2}" Margin="14,0,0,0" VerticalAlignment="Center" />
        </DockPanel>

        <Border Background="{DynamicResource X.Brush.GlassFill}" BorderBrush="{DynamicResource X.Brush.GlassBorder}"
                BorderThickness="1" CornerRadius="14" Padding="14">
          <StackPanel>
            <TextBlock Style="{StaticResource X.Text.Caption}" TextWrapping="Wrap" Margin="0,0,0,8"
                       Text="{loc:T settings.toolsCaption}" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Button Grid.Column="0" Content="{loc:T settings.toolsPrepare}" Command="{Binding BootstrapToolsCommand}"
                      Style="{StaticResource X.Btn.Primary}" />
              <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                         Text="{Binding BootstrapStatus}" TextWrapping="Wrap"
                         Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="12" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ======= FOLDERS ======= -->
      <StackPanel x:Name="PageFolders">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ElementName=rootView, Path=Page}" Value="folders">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Left" Style="{StaticResource X.Btn.Ghost}" Content="‹  Назад" Click="OnBackClick" />
          <TextBlock Text="{loc:T settings.folders}" Style="{StaticResource X.Text.H2}" Margin="14,0,0,0" VerticalAlignment="Center" />
        </DockPanel>

        <Border Background="{DynamicResource X.Brush.GlassFill}" BorderBrush="{DynamicResource X.Brush.GlassBorder}"
                BorderThickness="1" CornerRadius="14" Padding="14">
          <StackPanel>
            <TextBlock Text="{x:Static storage:AppDataPaths.XravRoot}" Foreground="{DynamicResource X.Brush.TextSoft}"
                       FontSize="11" TextWrapping="Wrap" />
            <TextBlock Text="{x:Static storage:AppDataPaths.ToolsDir}" Foreground="{DynamicResource X.Brush.TextSoft}"
                       FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0" />
            <TextBlock Text="{x:Static storage:AppDataPaths.XrayAssetDir}" Foreground="{DynamicResource X.Brush.TextSoft}"
                       FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0" />
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
              <Button Content="{loc:T settings.openData}" Command="{Binding OpenDataFolderCommand}" Style="{StaticResource X.Btn.Ghost}" Margin="0,0,8,0" />
              <Button Content="{loc:T settings.openLog}" Command="{Binding OpenLogFileCommand}" Style="{StaticResource X.Btn.Ghost}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ======= FAQ ======= -->
      <StackPanel x:Name="PageFaq">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ElementName=rootView, Path=Page}" Value="faq">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Left" Style="{StaticResource X.Btn.Ghost}" Content="‹  Назад" Click="OnBackClick" />
          <TextBlock Text="{loc:T settings.faq}" Style="{StaticResource X.Text.H2}" Margin="14,0,0,0" VerticalAlignment="Center" />
        </DockPanel>

        <Border Background="{DynamicResource X.Brush.GlassFill}" BorderBrush="{DynamicResource X.Brush.GlassBorder}"
                BorderThickness="1" CornerRadius="14" Padding="14">
          <StackPanel>
            <Expander Foreground="{DynamicResource X.Brush.Text}" Header="{loc:T faq.q1}" Margin="0,2">
              <TextBlock Text="{loc:T faq.a1}" TextWrapping="Wrap" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="12" Margin="4,4,0,4" />
            </Expander>
            <Expander Foreground="{DynamicResource X.Brush.Text}" Header="{loc:T faq.q2}" Margin="0,2">
              <TextBlock Text="{loc:T faq.a2}" TextWrapping="Wrap" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="12" Margin="4,4,0,4" />
            </Expander>
            <Expander Foreground="{DynamicResource X.Brush.Text}" Header="{loc:T faq.q3}" Margin="0,2">
              <TextBlock Text="{loc:T faq.a3}" TextWrapping="Wrap" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="12" Margin="4,4,0,4" />
            </Expander>
            <Expander Foreground="{DynamicResource X.Brush.Text}" Header="{loc:T faq.q4}" Margin="0,2">
              <TextBlock Text="{loc:T faq.a4}" TextWrapping="Wrap" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="12" Margin="4,4,0,4" />
            </Expander>
            <Expander Foreground="{DynamicResource X.Brush.Text}" Header="{loc:T faq.q5}" Margin="0,2">
              <TextBlock Text="{loc:T faq.a5}" TextWrapping="Wrap" Foreground="{DynamicResource X.Brush.TextSoft}" FontSize="12" Margin="4,4,0,4" />
            </Expander>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ======= ABOUT ======= -->
      <StackPanel x:Name="PageAbout">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ElementName=rootView, Path=Page}" Value="about">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Left" Style="{StaticResource X.Btn.Ghost}" Content="‹  Назад" Click="OnBackClick" />
          <TextBlock Text="{loc:T settings.about}" Style="{StaticResource X.Text.H2}" Margin="14,0,0,0" VerticalAlignment="Center" />
        </DockPanel>

        <Border Background="{DynamicResource X.Brush.GlassFill}" BorderBrush="{DynamicResource X.Brush.GlassBorder}"
                BorderThickness="1" CornerRadius="14" Padding="14">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{loc:T settings.version}" Foreground="{DynamicResource X.Brush.TextSoft}"
                         FontSize="12" Margin="0,0,8,0" />
              <TextBlock Grid.Column="1" Text="{Binding AppVersion}" Foreground="{DynamicResource X.Brush.Text}"
                         FontSize="12" FontWeight="SemiBold" />
            </Grid>

            <Grid Margin="0,6,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{loc:T settings.license}" Foreground="{DynamicResource X.Brush.TextSoft}"
                         FontSize="12" Margin="0,0,8,0" />
              <TextBlock Grid.Column="1" Text="{loc:T settings.licenseText}" Foreground="{DynamicResource X.Brush.Text}"
                         FontSize="12" FontWeight="SemiBold" />
            </Grid>

            <TextBlock Style="{StaticResource X.Text.Caption}" Margin="0,12,0,4" Text="{loc:T settings.website}" />
            <Button Content="rock.rockefellers.store" Command="{Binding OpenWebsiteCommand}"
                    HorizontalAlignment="Left" Style="{StaticResource X.Btn.Link}" />

            <TextBlock Style="{StaticResource X.Text.Caption}" Margin="0,10,0,4" Text="{loc:T settings.github}" />
            <Button Content="github.com/Maykl044/X-Raw" Command="{Binding OpenGithubCommand}"
                    HorizontalAlignment="Left" Style="{StaticResource X.Btn.Link}" />

            <TextBlock Style="{StaticResource X.Text.Caption}" Margin="0,10,0,4" Text="{loc:T settings.developers}" />
            <StackPanel Orientation="Horizontal">
              <Button Content="@igroutech" Command="{Binding OpenDeveloper1Command}" Style="{StaticResource X.Btn.Link}" Margin="0,0,12,0" />
              <Button Content="@BernarAr_no" Command="{Binding OpenDeveloper2Command}" Style="{StaticResource X.Btn.Link}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
