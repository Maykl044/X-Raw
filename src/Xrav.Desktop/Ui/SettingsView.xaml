<UserControl x:Class="Xrav.Desktop.Ui.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:storage="clr-namespace:Xrav.Desktop.Storage"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="16,0,16,8">
      <TextBlock Text="Настройки" Style="{StaticResource Xrav.Text.Title}" Margin="0,0,0,8" />

      <TextBlock Text="Бинарники xray-core / hev-socks5-tunnel / wintun" Style="{StaticResource Xrav.Text.Caption}" Margin="0,4,0,0" />
      <Grid Margin="0,4,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Content="Подготовить" Command="{Binding BootstrapToolsCommand}"
                Padding="12,4"
                Foreground="{StaticResource Xrav.Brush.TextPrimary}" Background="#33161A2B"
                BorderBrush="{StaticResource Xrav.Brush.Outline}" />
        <TextBlock Grid.Column="1" Margin="8,4,0,0"
                   Text="{Binding BootstrapStatus}" TextWrapping="Wrap"
                   Foreground="{StaticResource Xrav.Brush.TextSecondary}" />
      </Grid>
      <TextBlock Style="{StaticResource Xrav.Text.Caption}" TextWrapping="Wrap" Margin="0,4,0,0"
                 Text="Скачивает последний релиз xray-core (Xray-windows-64.zip), hev-socks5-tunnel (Windows x64) и кладёт wintun.dll. Geo-файлы — из v2fly/geoip и v2fly/domain-list-community." />

      <TextBlock Text="Папка данных" Style="{StaticResource Xrav.Text.Caption}" Margin="0,16,0,0" />
      <TextBlock Text="{x:Static storage:AppDataPaths.XravRoot}" Style="{StaticResource Xrav.Text.Caption}" TextWrapping="Wrap" />
      <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
        <Button Content="Открыть папку" Command="{Binding OpenDataFolderCommand}" Padding="10,4" Margin="0,0,6,0"
                Foreground="{StaticResource Xrav.Brush.TextPrimary}" Background="#33161A2B"
                BorderBrush="{StaticResource Xrav.Brush.Outline}" />
        <Button Content="Открыть лог" Command="{Binding OpenLogFileCommand}" Padding="10,4"
                Foreground="{StaticResource Xrav.Brush.TextPrimary}" Background="#33161A2B"
                BorderBrush="{StaticResource Xrav.Brush.Outline}" />
      </StackPanel>

      <TextBlock Text="Папка инструментов (xray.exe, wintun.dll, hev)" Style="{StaticResource Xrav.Text.Caption}" Margin="0,12,0,0" />
      <TextBlock Text="{x:Static storage:AppDataPaths.ToolsDir}" Style="{StaticResource Xrav.Text.Caption}" TextWrapping="Wrap" />

      <TextBlock Text="Папка geo (geoip.dat, geosite.dat) — XRAY_LOCATION_ASSET" Style="{StaticResource Xrav.Text.Caption}" Margin="0,8,0,0" />
      <TextBlock Text="{x:Static storage:AppDataPaths.XrayAssetDir}" Style="{StaticResource Xrav.Text.Caption}" TextWrapping="Wrap" />

      <TextBlock Text="Лог xray / hev" Style="{StaticResource Xrav.Text.Caption}" Margin="0,16,0,0" />
      <Grid Margin="0,4,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#33161A2B" BorderBrush="{StaticResource Xrav.Brush.Outline}" BorderThickness="1" CornerRadius="6" Padding="2"
                Margin="0,0,8,0">
          <ListBox ItemsSource="{Binding TunnelLog}" MaxHeight="200" MinHeight="80"
                   Background="Transparent" Foreground="{StaticResource Xrav.Brush.TextSecondary}" FontSize="11"
                   FontFamily="Consolas" BorderThickness="0" />
        </Border>
        <Button Grid.Column="1" Content="Очистить" VerticalAlignment="Top" Command="{Binding ClearTunnelLogCommand}"
                Padding="10,4" Foreground="{StaticResource Xrav.Brush.TextPrimary}" Background="#33161A2B"
                BorderBrush="{StaticResource Xrav.Brush.Outline}" />
      </Grid>

      <TextBlock Text="Версия" Style="{StaticResource Xrav.Text.Caption}" Margin="0,16,0,0" />
      <TextBlock Text="X-Rav для Windows · 1.0.0" Foreground="{StaticResource Xrav.Brush.TextPrimary}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
