<UserControl x:Class="Xrav.Desktop.Ui.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:storage="clr-namespace:Xrav.Desktop.Storage"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="500">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20,4,20,8">
      <TextBlock Text="Настройки" Style="{StaticResource X.Text.H2}" Margin="0,0,0,8" />

      <!-- Карточка: бинарники -->
      <Border Background="{StaticResource X.Brush.Surface}" BorderBrush="{StaticResource X.Brush.OutlineSoft}"
              BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,4,0,12">
        <StackPanel>
          <TextBlock Text="Бинарники" Style="{StaticResource X.Text.H2}" />
          <TextBlock Style="{StaticResource X.Text.Caption}" TextWrapping="Wrap" Margin="0,2,0,8"
                     Text="xray-core, hev-socks5-tunnel, sing-box, wintun.dll. Geo-файлы из v2fly/geoip + domain-list-community." />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Подготовить" Command="{Binding BootstrapToolsCommand}" Style="{StaticResource X.Btn.Primary}" />
            <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                       Text="{Binding BootstrapStatus}" TextWrapping="Wrap"
                       Foreground="{StaticResource X.Brush.TextSoft}" FontSize="12" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Карточка: пути -->
      <Border Background="{StaticResource X.Brush.Surface}" BorderBrush="{StaticResource X.Brush.OutlineSoft}"
              BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="Папки" Style="{StaticResource X.Text.H2}" />
          <TextBlock Style="{StaticResource X.Text.Caption}" Margin="0,8,0,0" Text="Данные приложения" />
          <TextBlock Text="{x:Static storage:AppDataPaths.XravRoot}" Foreground="{StaticResource X.Brush.TextSoft}"
                     FontSize="11" TextWrapping="Wrap" />
          <TextBlock Style="{StaticResource X.Text.Caption}" Margin="0,8,0,0" Text="Бинарники" />
          <TextBlock Text="{x:Static storage:AppDataPaths.ToolsDir}" Foreground="{StaticResource X.Brush.TextSoft}"
                     FontSize="11" TextWrapping="Wrap" />
          <TextBlock Style="{StaticResource X.Text.Caption}" Margin="0,8,0,0" Text="Geo-файлы (XRAY_LOCATION_ASSET)" />
          <TextBlock Text="{x:Static storage:AppDataPaths.XrayAssetDir}" Foreground="{StaticResource X.Brush.TextSoft}"
                     FontSize="11" TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Открыть папку" Command="{Binding OpenDataFolderCommand}" Style="{StaticResource X.Btn.Ghost}" Margin="0,0,8,0" />
            <Button Content="Открыть лог" Command="{Binding OpenLogFileCommand}" Style="{StaticResource X.Btn.Ghost}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Карточка: лог -->
      <Border Background="{StaticResource X.Brush.Surface}" BorderBrush="{StaticResource X.Brush.OutlineSoft}"
              BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,12">
        <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Лог процессов (xray / hev / sing-box)" Style="{StaticResource X.Text.H2}" />
            <Button Grid.Column="1" Content="Очистить" Command="{Binding ClearTunnelLogCommand}" Style="{StaticResource X.Btn.Ghost}" />
          </Grid>
          <Border Background="{StaticResource X.Brush.CanvasMid}" BorderBrush="{StaticResource X.Brush.OutlineSoft}"
                  BorderThickness="1" CornerRadius="10" Padding="2" Margin="0,8,0,0">
            <ListBox ItemsSource="{Binding TunnelLog}" MaxHeight="220" MinHeight="80"
                     Background="Transparent" Foreground="{StaticResource X.Brush.TextSoft}" FontSize="11"
                     FontFamily="Consolas" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
          </Border>
        </StackPanel>
      </Border>

      <TextBlock Text="X-Rav · 1.0 · Maykl044" Foreground="{StaticResource X.Brush.TextMuted}"
                 FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
