<Window x:Class="Xrav.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Xrav.Desktop.Ui"
        xmlns:loc="clr-namespace:Xrav.Desktop.Localization"
        Title="X-Rav"
        Icon="Assets/X-Rav.ico"
        Height="820" Width="500" MinWidth="440" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource X.Brush.Bg}"
        TextOptions.TextFormattingMode="Display">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <ui:NonEmptyStringToVisibilityConverter x:Key="StringToVis" />
    <ui:TunnelStateToColorConverter x:Key="StateToColor" />
    <ui:TunnelStateToPowerBrushConverter x:Key="StateToPowerBrush" />
  </Window.Resources>

  <Grid>
    <!-- Декоративная подсветка фона -->
    <Ellipse HorizontalAlignment="Right" VerticalAlignment="Top" Width="600" Height="600"
             Margin="0,-200,-200,0" Opacity="0.18">
      <Ellipse.Fill>
        <RadialGradientBrush>
          <GradientStop Color="{DynamicResource X.Color.BgGlow1}" Offset="0" />
          <GradientStop Color="{DynamicResource X.Color.BgGrad3}" Offset="1" />
        </RadialGradientBrush>
      </Ellipse.Fill>
    </Ellipse>
    <Ellipse HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="500" Height="500"
             Margin="-180,0,0,-200" Opacity="0.14">
      <Ellipse.Fill>
        <RadialGradientBrush>
          <GradientStop Color="{DynamicResource X.Color.BgGlow2}" Offset="0" />
          <GradientStop Color="{DynamicResource X.Color.BgGrad3}" Offset="1" />
        </RadialGradientBrush>
      </Ellipse.Fill>
    </Ellipse>

    <Grid Margin="0,0,0,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Шапка: лого + статус-пилюля -->
      <Grid Grid.Row="0" Margin="20,18,20,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="34" Height="34" CornerRadius="10" ClipToBounds="True">
            <Border.Background>
              <ImageBrush ImageSource="Assets/X-Rav.png" Stretch="UniformToFill" />
            </Border.Background>
          </Border>
          <TextBlock Text="X-Rav" Foreground="{DynamicResource X.Brush.Text}" FontWeight="Bold"
                     FontSize="20" Margin="10,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
        <Border Grid.Column="1" Background="{DynamicResource X.Brush.Surface}" CornerRadius="14"
                BorderBrush="{DynamicResource X.Brush.OutlineSoft}" BorderThickness="1" Padding="10,5">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                     Fill="{Binding TunnelState, Converter={StaticResource StateToColor}}" />
            <TextBlock Text="{Binding TunnelStateDisplay}" Foreground="{DynamicResource X.Brush.Text}"
                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Сообщение об ошибке + баннер обновления -->
      <StackPanel Grid.Row="1" Margin="20,12,20,0">
        <Border CornerRadius="10" Padding="12,8" Margin="0,0,0,6"
                Background="{DynamicResource X.Brush.DangerTint}" BorderBrush="{DynamicResource X.Brush.Danger}" BorderThickness="1"
                Visibility="{Binding TunnelError, Converter={StaticResource StringToVis}}">
          <TextBlock Text="{Binding TunnelError}" Foreground="{DynamicResource X.Brush.Text}"
                     FontSize="12" TextWrapping="Wrap" />
        </Border>
        <Border CornerRadius="10" Padding="12,8"
                Background="{DynamicResource X.Brush.WarnTint}" BorderBrush="{DynamicResource X.Brush.Warn}" BorderThickness="1"
                Visibility="{Binding UpdateBanner, Converter={StaticResource StringToVis}}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding UpdateBanner}" Foreground="{DynamicResource X.Brush.Text}"
                       FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="✕" Command="{Binding DismissUpdateBannerCommand}"
                    Background="Transparent" BorderThickness="0" Foreground="{DynamicResource X.Brush.TextSoft}"
                    FontSize="14" Padding="8,2" Cursor="Hand" />
          </Grid>
        </Border>
      </StackPanel>

      <!-- Большая кнопка питания -->
      <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,14,0,12">
        <Button Width="140" Height="140" Click="OnPowerClick" ToolTip="{Binding PowerHint}"
                Background="Transparent" BorderThickness="0" Cursor="Hand">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Grid>
                <Ellipse Width="140" Height="140"
                         Fill="{Binding TunnelState, Converter={StaticResource StateToPowerBrush}}" />
                <Ellipse Width="118" Height="118" StrokeThickness="2"
                         Stroke="{DynamicResource X.Brush.OutlineSoft}" Fill="{DynamicResource X.Brush.CanvasMid}" />
                <Ellipse Width="116" Height="116" StrokeThickness="1"
                         Stroke="{Binding TunnelState, Converter={StaticResource StateToColor}}" Opacity="0.5" />
                <Viewbox Width="46" Height="46">
                  <Path Stretch="Uniform"
                        Stroke="{Binding TunnelState, Converter={StaticResource StateToColor}}"
                        StrokeThickness="2.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                        Data="M 12 4 L 12 12 M 6 7 A 8 8 0 1 0 18 7" />
                </Viewbox>
              </Grid>
            </ControlTemplate>
          </Button.Template>
        </Button>
        <TextBlock Text="{Binding PowerHint}" Foreground="{DynamicResource X.Brush.TextSoft}"
                   FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" TextAlignment="Center" TextWrapping="Wrap" />
        <TextBlock Text="{Binding AutoStatusLine}" Foreground="{DynamicResource X.Brush.Accent2}"
                   FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0" TextAlignment="Center"
                   FontWeight="SemiBold" TextWrapping="Wrap"
                   Visibility="{Binding AutoSelectMode, Converter={StaticResource BoolToVisHelper}}" />
      </StackPanel>

      <!-- Контент таба -->
      <Grid Grid.Row="3" ClipToBounds="True">
        <ui:ServersView DataContext="{Binding}" Visibility="{Binding IsServersTab, Converter={StaticResource BoolToVis}}" />
        <ui:SubscriptionView DataContext="{Binding}" Visibility="{Binding IsSubscriptionTab, Converter={StaticResource BoolToVis}}" />
        <ui:LogView DataContext="{Binding}" Visibility="{Binding IsLogTab, Converter={StaticResource BoolToVis}}" />
        <ui:SettingsView DataContext="{Binding}" Visibility="{Binding IsSettingsTab, Converter={StaticResource BoolToVis}}" />
      </Grid>

      <!-- Нижняя навигация -->
      <Border Grid.Row="4" Margin="14,8,14,4" Background="{DynamicResource X.Brush.Surface}"
              BorderBrush="{DynamicResource X.Brush.OutlineSoft}" BorderThickness="1" CornerRadius="22" Padding="6">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
          </Grid.ColumnDefinitions>
          <ui:NavTab Grid.Column="0" Glyph="🌐" Title="{loc:T nav.servers}"      IsActive="{Binding IsServersTab}"      Command="{Binding GoServersCommand}" />
          <ui:NavTab Grid.Column="1" Glyph="🔗" Title="{loc:T nav.subscription}" IsActive="{Binding IsSubscriptionTab}" Command="{Binding GoSubscriptionCommand}" />
          <ui:NavTab Grid.Column="2" Glyph="📜" Title="{loc:T nav.log}"          IsActive="{Binding IsLogTab}"          Command="{Binding GoLogCommand}" />
          <ui:NavTab Grid.Column="3" Glyph="⚙"  Title="{loc:T nav.settings}"     IsActive="{Binding IsSettingsTab}"     Command="{Binding GoSettingsCommand}" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
