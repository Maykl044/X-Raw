<Window x:Class="Xrav.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Xrav.Desktop.Ui"
        xmlns:loc="clr-namespace:Xrav.Desktop.Localization"
        Title="X-Rav"
        Icon="Assets/X-Rav.ico"
        Height="760" Width="500" MinWidth="380" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource X.Brush.Bg}"
        TextOptions.TextFormattingMode="Display">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <ui:NonEmptyStringToVisibilityConverter x:Key="StringToVis" />
    <ui:TunnelStateToColorConverter x:Key="StateToColor" />
    <ui:TunnelStateToPowerBrushConverter x:Key="StateToPowerBrush" />
    <ui:TunnelStateMatchConverter x:Key="StateMatch" />

    <Storyboard x:Key="BgDrift" RepeatBehavior="Forever" AutoReverse="True">
      <DoubleAnimation Storyboard.TargetName="GlowAxform" Storyboard.TargetProperty="X"
                       From="0" To="-30" Duration="0:0:18" />
      <DoubleAnimation Storyboard.TargetName="GlowAxform" Storyboard.TargetProperty="Y"
                       From="0" To="40" Duration="0:0:18" />
      <DoubleAnimation Storyboard.TargetName="GlowBxform" Storyboard.TargetProperty="X"
                       From="0" To="38" Duration="0:0:22" />
      <DoubleAnimation Storyboard.TargetName="GlowBxform" Storyboard.TargetProperty="Y"
                       From="0" To="-26" Duration="0:0:22" />
      <DoubleAnimation Storyboard.TargetName="GlowCxform" Storyboard.TargetProperty="X"
                       From="-25" To="25" Duration="0:0:14" />
      <DoubleAnimation Storyboard.TargetName="GlowCxform" Storyboard.TargetProperty="Y"
                       From="-15" To="20" Duration="0:0:14" />
      <DoubleAnimation Storyboard.TargetName="GlowA" Storyboard.TargetProperty="Opacity"
                       From="0.30" To="0.20" Duration="0:0:10" />
      <DoubleAnimation Storyboard.TargetName="GlowB" Storyboard.TargetProperty="Opacity"
                       From="0.24" To="0.32" Duration="0:0:12" />
    </Storyboard>
  </Window.Resources>
  <Window.Triggers>
    <EventTrigger RoutedEvent="Window.Loaded">
      <BeginStoryboard Storyboard="{StaticResource BgDrift}" />
    </EventTrigger>
  </Window.Triggers>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Анимированная подсветка фона (iOS 26 / Liquid Glass) — два «солнца» из акцентных
         цветов с медленным дрейфом + слой частиц. Тонкая, не отвлекающая. -->
    <Grid x:Name="BgLayer" Grid.ColumnSpan="2" IsHitTestVisible="False">
      <Ellipse x:Name="GlowA" Width="640" Height="640" HorizontalAlignment="Right" VerticalAlignment="Top"
               Margin="0,-220,-220,0" Opacity="0.30">
        <Ellipse.RenderTransform>
          <TranslateTransform x:Name="GlowAxform" />
        </Ellipse.RenderTransform>
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="{DynamicResource X.Color.BgGlow1}" Offset="0" />
            <GradientStop Color="#00000000" Offset="1" />
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>
      <Ellipse x:Name="GlowB" Width="540" Height="540" HorizontalAlignment="Left" VerticalAlignment="Bottom"
               Margin="-200,0,0,-200" Opacity="0.24">
        <Ellipse.RenderTransform>
          <TranslateTransform x:Name="GlowBxform" />
        </Ellipse.RenderTransform>
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="{DynamicResource X.Color.BgGlow2}" Offset="0" />
            <GradientStop Color="#00000000" Offset="1" />
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>
      <Ellipse x:Name="GlowC" Width="420" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center"
               Opacity="0.12">
        <Ellipse.RenderTransform>
          <TranslateTransform x:Name="GlowCxform" />
        </Ellipse.RenderTransform>
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="{DynamicResource X.Color.Accent}" Offset="0" />
            <GradientStop Color="#00000000" Offset="1" />
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>
    </Grid>
    <ui:ParticleField Grid.ColumnSpan="2" IsHitTestVisible="False" />

    <!-- Brushed-metal sidebar: появляется при ActualWidth >= 900 (adaptive layout).
         Внутри — вертикальная навигация по тем же 4 вкладкам что и в нижнем баре. -->
    <Border Grid.Column="0" Width="220" Style="{StaticResource X.Panel.BrushedMetal}"
            Visibility="{Binding IsWideLayout, Converter={StaticResource BoolToVisHelper}}">
      <Grid>
        <!-- Шлифовка поверх (тонкие горизонтальные штрихи + шум) -->
        <Rectangle Fill="{DynamicResource X.Brush.BrushedScratches}" IsHitTestVisible="False" />
        <Rectangle Fill="{DynamicResource X.Brush.GrainOverlay}" IsHitTestVisible="False" />
        <StackPanel Margin="10,20,10,20">
          <StackPanel Orientation="Horizontal" Margin="6,0,0,24">
            <Border Width="34" Height="34" CornerRadius="10" ClipToBounds="True">
              <Border.Background>
                <ImageBrush ImageSource="Assets/X-Rav.png" Stretch="UniformToFill" />
              </Border.Background>
            </Border>
            <TextBlock Text="X-Rav" Foreground="{DynamicResource X.Brush.Text}" FontWeight="Bold"
                       FontSize="18" Margin="10,0,0,0" VerticalAlignment="Center" />
          </StackPanel>
          <ui:NavTab Glyph="🌐" Title="{loc:T nav.servers}"      IsActive="{Binding IsServersTab}"      Command="{Binding GoServersCommand}"      Margin="0,2" />
          <ui:NavTab Glyph="🔗" Title="{loc:T nav.subscription}" IsActive="{Binding IsSubscriptionTab}" Command="{Binding GoSubscriptionCommand}" Margin="0,2" />
          <ui:NavTab Glyph="📜" Title="{loc:T nav.log}"          IsActive="{Binding IsLogTab}"          Command="{Binding GoLogCommand}"          Margin="0,2" />
          <ui:NavTab Glyph="⚙"  Title="{loc:T nav.settings}"     IsActive="{Binding IsSettingsTab}"     Command="{Binding GoSettingsCommand}"     Margin="0,2" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1" Margin="0,0,0,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Шапка: лого + статус-пилюля -->
      <Grid Grid.Row="0" Margin="20,10,20,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="34" Height="34" CornerRadius="10" ClipToBounds="True">
            <Border.Background>
              <ImageBrush ImageSource="Assets/X-Rav.png" Stretch="UniformToFill" />
            </Border.Background>
          </Border>
          <TextBlock Text="X-Rav" Foreground="{DynamicResource X.Brush.Text}" FontWeight="Bold"
                     FontSize="20" Margin="10,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="RefreshSubBtn" Command="{Binding RefreshActiveSubscriptionCommand}"
                  Style="{StaticResource X.Btn.Ghost}" Padding="10,6" Margin="0,0,8,0"
                  ToolTip="Обновить текущую подписку"
                  Visibility="{Binding HasSubscriptions, Converter={StaticResource BoolToVisHelper}}">
            <TextBlock Text="↻" FontSize="15" FontWeight="Bold" />
          </Button>
          <Border Background="{DynamicResource X.Brush.GlassFill}" CornerRadius="14"
                  BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1" Padding="10,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                       Fill="{Binding TunnelState, Converter={StaticResource StateToColor}}" />
              <TextBlock Text="{Binding TunnelStateDisplay}" Foreground="{DynamicResource X.Brush.Text}"
                         FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>

      <!-- Сообщение об ошибке + баннер обновления -->
      <StackPanel Grid.Row="1" Margin="20,6,20,0">
        <Border CornerRadius="10" Padding="12,8" Margin="0,0,0,6"
                Background="{DynamicResource X.Brush.DangerTint}" BorderBrush="{DynamicResource X.Brush.Danger}" BorderThickness="1"
                Visibility="{Binding TunnelError, Converter={StaticResource StringToVis}}">
          <TextBlock Text="{Binding TunnelError}" Foreground="{DynamicResource X.Brush.Text}"
                     FontSize="12" TextWrapping="Wrap" />
        </Border>
        <Border CornerRadius="10" Padding="12,8"
                Background="{DynamicResource X.Brush.WarnTint}" BorderBrush="{DynamicResource X.Brush.Warn}" BorderThickness="1"
                Visibility="{Binding UpdateBanner, Converter={StaticResource StringToVis}}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding UpdateBanner}" Foreground="{DynamicResource X.Brush.Text}"
                       FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="✕" Command="{Binding DismissUpdateBannerCommand}"
                    Background="Transparent" BorderThickness="0" Foreground="{DynamicResource X.Brush.TextSoft}"
                    FontSize="14" Padding="8,2" Cursor="Hand" />
          </Grid>
        </Border>
      </StackPanel>

      <!-- Кнопка питания: Orbot-style стеклянный купол.
           Слои: smart-radar / idle-pulse halo / connected-aurora / connecting-ring / glass orb / power glyph.
           Весь блок обёрнут Viewbox 190×190 — все слои и анимации пропорционально
           сжаты, чтобы экономить вертикальное место для списка ключей. -->
      <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,2,0,2">
        <Viewbox Width="170" Height="170" Stretch="Uniform" HorizontalAlignment="Center">
        <Grid Width="260" Height="260" HorizontalAlignment="Center">

          <!-- 0. SMART-RADAR: три расходящиеся волны от центра + scanning arc.
               Активны когда AutoSelectMode=True (умный режим) — антенна "ищет" сервер. -->
          <Grid Visibility="{Binding AutoSelectMode, Converter={StaticResource BoolToVisHelper}}">
            <Grid.Resources>
              <Style x:Key="RadarRing" TargetType="Ellipse">
                <Setter Property="Stroke" Value="{DynamicResource X.Brush.Accent}" />
                <Setter Property="StrokeThickness" Value="2" />
                <Setter Property="Opacity" Value="0" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
              </Style>
            </Grid.Resources>
            <Grid.Triggers>
              <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                  <Storyboard RepeatBehavior="Forever" Duration="0:0:2.4">
                    <!-- Wave 1 -->
                    <DoubleAnimation Storyboard.TargetName="RadarA" Storyboard.TargetProperty="Opacity"
                                     From="0.75" To="0" Duration="0:0:2.4" BeginTime="0:0:0" />
                    <DoubleAnimation Storyboard.TargetName="RadarA" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     From="0.30" To="1.10" Duration="0:0:2.4" BeginTime="0:0:0" />
                    <DoubleAnimation Storyboard.TargetName="RadarA" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     From="0.30" To="1.10" Duration="0:0:2.4" BeginTime="0:0:0" />
                    <!-- Wave 2 -->
                    <DoubleAnimation Storyboard.TargetName="RadarB" Storyboard.TargetProperty="Opacity"
                                     From="0.75" To="0" Duration="0:0:2.4" BeginTime="0:0:0.8" />
                    <DoubleAnimation Storyboard.TargetName="RadarB" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     From="0.30" To="1.10" Duration="0:0:2.4" BeginTime="0:0:0.8" />
                    <DoubleAnimation Storyboard.TargetName="RadarB" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     From="0.30" To="1.10" Duration="0:0:2.4" BeginTime="0:0:0.8" />
                    <!-- Wave 3 -->
                    <DoubleAnimation Storyboard.TargetName="RadarC" Storyboard.TargetProperty="Opacity"
                                     From="0.75" To="0" Duration="0:0:2.4" BeginTime="0:0:1.6" />
                    <DoubleAnimation Storyboard.TargetName="RadarC" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     From="0.30" To="1.10" Duration="0:0:2.4" BeginTime="0:0:1.6" />
                    <DoubleAnimation Storyboard.TargetName="RadarC" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     From="0.30" To="1.10" Duration="0:0:2.4" BeginTime="0:0:1.6" />
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </Grid.Triggers>
            <Ellipse x:Name="RadarA" Width="240" Height="240" Style="{StaticResource RadarRing}">
              <Ellipse.RenderTransform><ScaleTransform ScaleX="0.30" ScaleY="0.30" /></Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="RadarB" Width="240" Height="240" Style="{StaticResource RadarRing}">
              <Ellipse.RenderTransform><ScaleTransform ScaleX="0.30" ScaleY="0.30" /></Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="RadarC" Width="240" Height="240" Style="{StaticResource RadarRing}">
              <Ellipse.RenderTransform><ScaleTransform ScaleX="0.30" ScaleY="0.30" /></Ellipse.RenderTransform>
            </Ellipse>
            <!-- Сканирующая дуга поверх — вращается, имитирует радар-стрелку -->
            <Path Width="240" Height="240" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Opacity="0.55" RenderTransformOrigin="0.5,0.5"
                  Data="M 120 8 A 112 112 0 0 1 215 70">
              <Path.Stroke>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="{DynamicResource X.Color.Accent}" Offset="0" />
                  <GradientStop Color="{DynamicResource X.Color.Accent2}" Offset="1" />
                </LinearGradientBrush>
              </Path.Stroke>
              <Path.RenderTransform><RotateTransform Angle="0" /></Path.RenderTransform>
              <Path.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                  <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                      <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                       From="0" To="360" Duration="0:0:3.2" />
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </Path.Triggers>
            </Path>
            <!-- Маленькие точки-узлы на расстоянии (визуализация "найденных серверов") -->
            <Canvas Width="240" Height="240">
              <Ellipse Canvas.Left="40"  Canvas.Top="60"  Width="6" Height="6" Fill="{DynamicResource X.Brush.Accent}"  Opacity="0.8" />
              <Ellipse Canvas.Left="190" Canvas.Top="110" Width="6" Height="6" Fill="{DynamicResource X.Brush.Accent2}" Opacity="0.7" />
              <Ellipse Canvas.Left="76"  Canvas.Top="200" Width="6" Height="6" Fill="{DynamicResource X.Brush.Accent}"  Opacity="0.6" />
              <Ellipse Canvas.Left="160" Canvas.Top="40"  Width="5" Height="5" Fill="{DynamicResource X.Brush.Accent2}" Opacity="0.5" />
            </Canvas>
          </Grid>

          <!-- 1. IDLE: мягкая пульсация акцентного ореола -->
          <Ellipse Width="200" Height="200" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Ellipse.Fill>
              <RadialGradientBrush>
                <GradientStop Color="{DynamicResource X.Color.Accent}" Offset="0.45" />
                <GradientStop Color="#00000000" Offset="1" />
              </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.RenderTransform>
              <ScaleTransform ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding TunnelState, Converter={StaticResource StateMatch}, ConverterParameter=Idle}" Value="True">
                    <DataTrigger.EnterActions>
                      <BeginStoryboard Name="IdleSb">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                          <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                           From="0.18" To="0.50" Duration="0:0:2.0" />
                          <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                           From="0.92" To="1.06" Duration="0:0:2.0" />
                          <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                           From="0.92" To="1.06" Duration="0:0:2.0" />
                        </Storyboard>
                      </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                      <StopStoryboard BeginStoryboardName="IdleSb" />
                    </DataTrigger.ExitActions>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>

          <!-- 2. CONNECTED: aurora — две дрейфующие эллипсы (каждая анимируется сама) -->
          <Ellipse Width="190" Height="190" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform><TranslateTransform X="0" Y="0" /></Ellipse.RenderTransform>
            <Ellipse.Fill>
              <RadialGradientBrush>
                <GradientStop Color="{DynamicResource X.Color.PowerOn1}" Offset="0" />
                <GradientStop Color="#00000000" Offset="1" />
              </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect><BlurEffect Radius="14" /></Ellipse.Effect>
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding TunnelState, Converter={StaticResource StateMatch}, ConverterParameter=Connected}" Value="True">
                    <DataTrigger.EnterActions>
                      <BeginStoryboard Name="AurASb">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                           To="0.7" Duration="0:0:0.6" />
                          <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                           From="-26" To="26" Duration="0:0:5" AutoReverse="True" RepeatBehavior="Forever" />
                          <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                           From="14" To="-14" Duration="0:0:7" AutoReverse="True" RepeatBehavior="Forever" />
                        </Storyboard>
                      </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                      <StopStoryboard BeginStoryboardName="AurASb" />
                    </DataTrigger.ExitActions>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>
          <Ellipse Width="170" Height="170" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform><TranslateTransform X="0" Y="0" /></Ellipse.RenderTransform>
            <Ellipse.Fill>
              <RadialGradientBrush>
                <GradientStop Color="{DynamicResource X.Color.Accent2}" Offset="0" />
                <GradientStop Color="#00000000" Offset="1" />
              </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect><BlurEffect Radius="16" /></Ellipse.Effect>
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding TunnelState, Converter={StaticResource StateMatch}, ConverterParameter=Connected}" Value="True">
                    <DataTrigger.EnterActions>
                      <BeginStoryboard Name="AurBSb">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                           To="0.6" Duration="0:0:0.6" />
                          <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                           From="22" To="-22" Duration="0:0:6" AutoReverse="True" RepeatBehavior="Forever" />
                          <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                           From="-12" To="16" Duration="0:0:8" AutoReverse="True" RepeatBehavior="Forever" />
                        </Storyboard>
                      </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                      <StopStoryboard BeginStoryboardName="AurBSb" />
                    </DataTrigger.ExitActions>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>

          <!-- 3. CONNECTING: вращающееся пунктирное кольцо -->
          <Ellipse Width="186" Height="186" StrokeThickness="2.5"
                   Stroke="{DynamicResource X.Brush.Accent}"
                   StrokeDashArray="2 4" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
              <RotateTransform Angle="0" />
            </Ellipse.RenderTransform>
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding TunnelState, Converter={StaticResource StateMatch}, ConverterParameter=Connecting}" Value="True">
                    <DataTrigger.EnterActions>
                      <BeginStoryboard Name="ConnRingSb">
                        <Storyboard RepeatBehavior="Forever">
                          <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                           From="0" To="360" Duration="0:0:2.4" />
                          <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                           From="0.55" To="0.95" Duration="0:0:0.9" AutoReverse="True"
                                           RepeatBehavior="Forever" />
                        </Storyboard>
                      </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                      <StopStoryboard BeginStoryboardName="ConnRingSb" />
                    </DataTrigger.ExitActions>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>

          <!-- 4. ERROR: красное мигание -->
          <Ellipse Width="186" Height="186" StrokeThickness="2"
                   Stroke="{DynamicResource X.Brush.Danger}" Opacity="0">
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding TunnelState, Converter={StaticResource StateMatch}, ConverterParameter=Error}" Value="True">
                    <DataTrigger.EnterActions>
                      <BeginStoryboard Name="ErrSb">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                           From="0" To="0.85" Duration="0:0:0.4"
                                           AutoReverse="True" RepeatBehavior="Forever" />
                        </Storyboard>
                      </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                      <StopStoryboard BeginStoryboardName="ErrSb" />
                    </DataTrigger.ExitActions>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>

          <!-- 5. Сам стеклянный купол с power-иконкой -->
          <Button Width="156" Height="156" Click="OnPowerClick" ToolTip="{Binding PowerHint}"
                  Background="Transparent" BorderThickness="0" Cursor="Hand"
                  RenderTransformOrigin="0.5,0.5">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Grid>
                  <!-- Внешняя стеклянная сфера: радиальный градиент power on/off -->
                  <Ellipse Width="156" Height="156"
                           Fill="{Binding TunnelState, Converter={StaticResource StateToPowerBrush}}">
                    <Ellipse.Effect>
                      <DropShadowEffect Color="{DynamicResource X.Color.GlassShadow}" BlurRadius="28"
                                        ShadowDepth="0" Opacity="0.55" />
                    </Ellipse.Effect>
                  </Ellipse>
                  <!-- Frosted-стекло слой -->
                  <Ellipse Width="132" Height="132"
                           Fill="{DynamicResource X.Brush.GlassFillStrong}"
                           Stroke="{DynamicResource X.Brush.GlassBorder}" StrokeThickness="1.2" />
                  <!-- Верхний highlight (sheen) -->
                  <Ellipse Width="132" Height="132">
                    <Ellipse.Fill>
                      <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="{DynamicResource X.Color.GlassHighlight}" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="0.55" />
                      </LinearGradientBrush>
                    </Ellipse.Fill>
                  </Ellipse>
                  <!-- Внутреннее цветное кольцо состояния -->
                  <Ellipse Width="118" Height="118" StrokeThickness="1.4"
                           Stroke="{Binding TunnelState, Converter={StaticResource StateToColor}}" Opacity="0.6" />
                  <!-- Power-glyph -->
                  <Viewbox Width="50" Height="50">
                    <Path Stretch="Uniform"
                          Stroke="{Binding TunnelState, Converter={StaticResource StateToColor}}"
                          StrokeThickness="2.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 12 4 L 12 12 M 6 7 A 8 8 0 1 0 18 7" />
                  </Viewbox>
                </Grid>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </Grid>
        </Viewbox>
        <TextBlock Text="{Binding PowerHint}" Foreground="{DynamicResource X.Brush.TextSoft}"
                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" TextAlignment="Center" TextWrapping="Wrap" />
        <TextBlock Text="{Binding AutoStatusLine}" Foreground="{DynamicResource X.Brush.Accent2}"
                   FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" TextAlignment="Center"
                   FontWeight="SemiBold" TextWrapping="Wrap"
                   Visibility="{Binding AutoSelectMode, Converter={StaticResource BoolToVisHelper}}" />
        <!-- Проверка текущего подключения: видна только при Connected; жмёт TLS/Reality handshake к активному ключу -->
        <Button Command="{Binding CheckHandshakeCommand}"
                Style="{StaticResource X.Btn.Ghost}"
                HorizontalAlignment="Center" Margin="0,6,0,0" Padding="12,5"
                ToolTip="Проверить, действительно ли активный сервер отвечает на TLS/Reality рукопожатие"
                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisHelper}}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="✓" FontSize="13" FontWeight="Bold" Margin="0,0,8,0"
                       Foreground="{DynamicResource X.Brush.Success}" VerticalAlignment="Center" />
            <TextBlock Text="Проверить текущее подключение" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </StackPanel>

      <!-- Контент таба -->
      <Grid Grid.Row="3" ClipToBounds="True">
        <ui:ServersView DataContext="{Binding}" Visibility="{Binding IsServersTab, Converter={StaticResource BoolToVis}}" />
        <ui:SubscriptionView DataContext="{Binding}" Visibility="{Binding IsSubscriptionTab, Converter={StaticResource BoolToVis}}" />
        <ui:LogView DataContext="{Binding}" Visibility="{Binding IsLogTab, Converter={StaticResource BoolToVis}}" />
        <ui:SettingsView DataContext="{Binding}" Visibility="{Binding IsSettingsTab, Converter={StaticResource BoolToVis}}" />
      </Grid>

      <!-- Нижняя навигация (скрывается когда доступен sidebar) -->
      <Border Grid.Row="4" Margin="14,8,14,4" Background="{DynamicResource X.Brush.GlassFill}"
              BorderBrush="{DynamicResource X.Brush.GlassBorder}" BorderThickness="1" CornerRadius="22" Padding="6"
              Visibility="{Binding IsNarrowLayout, Converter={StaticResource BoolToVisHelper}}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
          </Grid.ColumnDefinitions>
          <ui:NavTab Grid.Column="0" Glyph="🌐" Title="{loc:T nav.servers}"      IsActive="{Binding IsServersTab}"      Command="{Binding GoServersCommand}" />
          <ui:NavTab Grid.Column="1" Glyph="🔗" Title="{loc:T nav.subscription}" IsActive="{Binding IsSubscriptionTab}" Command="{Binding GoSubscriptionCommand}" />
          <ui:NavTab Grid.Column="2" Glyph="📜" Title="{loc:T nav.log}"          IsActive="{Binding IsLogTab}"          Command="{Binding GoLogCommand}" />
          <ui:NavTab Grid.Column="3" Glyph="⚙"  Title="{loc:T nav.settings}"     IsActive="{Binding IsSettingsTab}"     Command="{Binding GoSettingsCommand}" />
        </Grid>
      </Border>
    </Grid>

    <!-- Toast-уведомление: всплывает сверху при успешном/ошибочном обновлении подписки -->
    <Border x:Name="Toast" Grid.ColumnSpan="2" VerticalAlignment="Top" HorizontalAlignment="Center"
            Margin="0,18,0,0" CornerRadius="14" Padding="14,10" MaxWidth="440"
            BorderThickness="1" Cursor="Hand"
            MouseLeftButtonUp="OnToastClick"
            Visibility="{Binding ToastVisible, Converter={StaticResource BoolToVis}}"
            RenderTransformOrigin="0.5,0">
      <Border.RenderTransform>
        <TranslateTransform X="0" Y="-30" />
      </Border.RenderTransform>
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Background" Value="{DynamicResource X.Brush.GlassFillStrong}" />
          <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.Accent}" />
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="{DynamicResource X.Color.GlassShadow}" BlurRadius="20" ShadowDepth="0" Opacity="0.55" />
            </Setter.Value>
          </Setter>
          <Style.Triggers>
            <DataTrigger Binding="{Binding ToastKind}" Value="success">
              <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.Success}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding ToastKind}" Value="error">
              <Setter Property="BorderBrush" Value="{DynamicResource X.Brush.Danger}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding ToastVisible}" Value="True">
              <DataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.30" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="-30" To="0" Duration="0:0:0.30">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel Orientation="Horizontal">
        <TextBlock VerticalAlignment="Center" FontSize="16" Margin="0,0,8,0">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Text" Value="ⓘ" />
              <Setter Property="Foreground" Value="{DynamicResource X.Brush.Accent2}" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding ToastKind}" Value="success">
                  <Setter Property="Text" Value="✓" />
                  <Setter Property="Foreground" Value="{DynamicResource X.Brush.Success}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ToastKind}" Value="error">
                  <Setter Property="Text" Value="✕" />
                  <Setter Property="Foreground" Value="{DynamicResource X.Brush.Danger}" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <TextBlock Text="{Binding ToastText}" Foreground="{DynamicResource X.Brush.Text}"
                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                   TextWrapping="Wrap" MaxWidth="380" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
