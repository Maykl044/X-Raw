<Application x:Class="Xrav.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:Xrav.Desktop.Ui"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Theme/Colors.Dark.xaml" />
        <ResourceDictionary Source="Theme/XravTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <ui:ZeroToVisibleConverter x:Key="ZeroToVisible" />
      <ui:StrEqualsConverter x:Key="StrEqualsConverter" />
      <ui:CountryFlagImageConverter x:Key="FlagImage" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
